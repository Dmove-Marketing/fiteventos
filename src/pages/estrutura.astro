<script>
  import "../scripts/institucional.js";

  // Vgroup carousels (horizontal, slide by visible count)
  document.querySelectorAll<HTMLElement>('[data-vgroup-carousel]').forEach((carousel) => {
    const track = carousel.querySelector<HTMLElement>('.vgroup-track')!;
    const slides = Array.from(carousel.querySelectorAll<HTMLElement>('.vgroup-slide'));
    let current = 0;

    function visibleCount() {
      return window.innerWidth < 600 ? 1 : window.innerWidth < 900 ? 2 : 3;
    }

    function maxIndex() {
      return Math.max(0, slides.length - visibleCount());
    }

    function go(idx: number) {
      current = Math.max(0, Math.min(idx, maxIndex()));
      const slideW = slides[0].offsetWidth + 12; // width + gap
      track.style.transform = `translateX(-${current * slideW}px)`;
    }

    carousel.querySelector('.vgroup-prev')?.addEventListener('click', () => go(current - 1));
    carousel.querySelector('.vgroup-next')?.addEventListener('click', () => go(current + 1));
    window.addEventListener('resize', () => go(current));
  });

  document.querySelectorAll<HTMLElement>('[data-espaco-carousel]').forEach((carousel) => {
    const track = carousel.querySelector<HTMLElement>('.espaco-carousel-track')!;
    const origSlides = Array.from(carousel.querySelectorAll<HTMLElement>('.espaco-carousel-slide'));
    const total = origSlides.length;

    // Clone slides for infinite loop
    origSlides.forEach(s => track.appendChild(s.cloneNode(true)));
    const allSlides = Array.from(track.querySelectorAll<HTMLElement>('.espaco-carousel-slide'));

    let current = 0;

    function setWidths() {
      const w = carousel.offsetWidth;
      allSlides.forEach(s => { s.style.width = w + 'px'; });
      track.style.transition = 'none';
      track.style.transform = `translateX(-${current * carousel.offsetWidth}px)`;
    }
    setWidths();
    window.addEventListener('resize', setWidths);

    function next() {
      current++;
      track.style.transition = 'transform 0.65s ease';
      track.style.transform = `translateX(-${current * carousel.offsetWidth}px)`;

      // When we reach the cloned set, silently jump back
      track.addEventListener('transitionend', function onEnd() {
        track.removeEventListener('transitionend', onEnd);
        if (current >= total) {
          current = 0;
          track.style.transition = 'none';
          track.style.transform = `translateX(0)`;
        }
      });
    }

    setInterval(next, 4000);
  });
</script>

