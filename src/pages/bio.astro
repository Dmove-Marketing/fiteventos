---
// Componente gerado a partir de: bio.html
import '../styles/bio.css';
import LeadForm from '../components/forms/LeadForm.astro';
---

<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Casa Voss — Solicitação de Reserva</title>
    <meta name="description"
        content="Solicite sua reserva no Casa Voss. Espaço de eventos corporativos em São Paulo com auditório, salas, gourmet e lounge para até 250 pessoas." />
    <meta property="og:title" content="Casa Voss — Solicitação de Reserva" />
    <meta property="og:description"
        content="Exclusividade para eventos que pedem mais. Solicite seu orçamento na Casa Voss." />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pt_BR" />
    <link rel="icon"
        href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🌿</text></svg>" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://use.typekit.net/ruo8uhd.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@200;300;400;500;700&display=swap"
        rel="stylesheet" />
    <link rel="stylesheet" href="https://npmcdn.com/flatpickr/dist/flatpickr.min.css" />

    
    

    
</head>

<body>

    <noscript></noscript>

    <section class="bio-hero">
        <div class="bio-bg"></div>
        <div class="bio-overlay"></div>
        <div class="bio-content">
            <span class="bio-tag">Exclusividade</span>
            <h1 class="bio-heading">Uma casa que transforma<br>encontros em<em> experiências</em></h1>
            <h2 class="bio-subheading">Seu evento. Sua essência. Sua Voss.</h2>
            <div class="bio-form-card">
                <LeadForm
                    formId="bio"
                    project="casavoss"
                    submitUrl="https://server3n8n.dmove.com.br/webhook/casa-voss"
                    submitText="ENVIAR SOLICITAÇÃO"
                    prefix="bio"
                    gridId="bioFormGrid"
                    submitId="bioSubmitBtn"
                    honeypot={true}
                    successTitle="Solicitação recebida"
                    successText="Recebemos seu pedido de orçamento.<br>Em breve entraremos em contato pelo WhatsApp ou e-mail."
                    fields={[
                        { name: 'form_fields[nome]', id: 'Nome', type: 'text', label: 'Nome', placeholder: 'Nome', autocomplete: 'given-name', maxlength: 100, required: true, full: true, errorText: 'Informe seu nome.', errorId: 'errNome' },
                        {
                            type: 'row',
                            fields: [
                                { name: 'form_fields[telefone]', id: 'Telefone', type: 'tel', label: 'WhatsApp', placeholder: '(11) 9 0000-0000', autocomplete: 'tel', maxlength: 20, required: true, errorText: 'Informe um WhatsApp válido.', errorId: 'errTelefone' },
                                { name: 'form_fields[email]', id: 'Email', type: 'email', label: 'E-mail', placeholder: 'E-mail', autocomplete: 'email', maxlength: 200, required: true, errorText: 'Informe um e-mail válido.', errorId: 'errEmail' },
                            ]
                        },
                        {
                            name: 'form_fields[tipo]', id: 'Tipo', type: 'select', label: 'Tipo de evento', required: true, full: true,
                            errorText: 'Selecione o tipo de evento.', errorId: 'errTipo',
                            options: [
                                { value: '', label: 'Tipo de evento', disabled: true, selected: true },
                                { value: 'Aniversário', label: 'Aniversário' },
                                { value: 'Aniversário debutante', label: 'Aniversário debutante' },
                                { value: 'Bodas', label: 'Bodas' },
                                { value: 'Casamento', label: 'Casamento' },
                                { value: 'Confraternização corporativa', label: 'Confraternização corporativa' },
                                { value: 'Confraternização social', label: 'Confraternização social' },
                                { value: 'Corporativo', label: 'Corporativo' },
                                { value: 'Feiras e Exposições', label: 'Feiras e Exposições' },
                                { value: 'Formatura', label: 'Formatura' },
                                { value: 'Happy Hour', label: 'Happy Hour' },
                                { value: 'Masterclass e Palestras', label: 'Masterclass e Palestras' },
                                { value: 'Mentorias e Treinamentos', label: 'Mentorias e Treinamentos' },
                                { value: 'Offsite corporativo', label: 'Offsite corporativo' },
                                { value: 'Reuniões de Networking', label: 'Reuniões de Networking' },
                                { value: 'Shows e Festivais', label: 'Shows e Festivais' },
                                { value: 'Workshops, Conferências e Seminários', label: 'Workshops, Conferências e Seminários' },
                                { value: 'Outros', label: 'Outros' },
                            ]
                        },
                        { name: 'form_fields[data]', id: 'Data', type: 'text', label: 'Data do evento', placeholder: 'Data do evento', readonly: true, required: true, full: true, errorText: 'Informe a data do evento.', errorId: 'errData' },
                        { name: 'form_fields[convidados]', id: 'Convidados', type: 'number', label: 'Convidados', placeholder: 'N° de Pessoas', required: true, full: true, errorText: 'Informe o número de pessoas.', errorId: 'errConvidados' },
                        { name: 'form_fields[mensagem]', id: 'Mensagem', type: 'textarea', label: 'Mensagem', placeholder: 'Detalhes adicionais: (Não obrigatório)', rows: 4, full: true },
                        { name: 'form_fields[fonte]', id: 'Fonte', type: 'hidden', value: 'Landing page/bio' },
                    ]}
                />
            </div>
        </div>
    </section>

    <a href="#" id="wppFloatBtn" class="wpp-float" aria-label="Abrir WhatsApp">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1219.547 1225.016">
            <path fill="#E0E0E0"
                d="M1041.858 178.02C927.206 63.289 774.753.07 612.325 0 277.617 0 5.232 272.298 5.098 606.991c-.039 106.986 27.915 211.42 81.048 303.476L0 1225.016l321.898-84.406c88.689 48.368 188.547 73.855 290.166 73.896h.258.003c334.654 0 607.08-272.346 607.222-607.023.056-162.208-63.052-314.724-177.689-429.463zm-429.533 933.963h-.197c-90.578-.048-179.402-24.366-256.878-70.339l-18.438-10.93-191.021 50.083 51-186.176-12.013-19.087c-50.525-80.336-77.198-173.175-77.16-268.504.111-278.186 226.507-504.503 504.898-504.503 134.812.056 261.519 52.604 356.814 147.965 95.289 95.36 147.728 222.128 147.688 356.948-.118 278.195-226.522 504.543-504.693 504.543z" />
            <linearGradient id="a" gradientUnits="userSpaceOnUse" x1="609.77" y1="1190.114" x2="609.77" y2="21.084">
                <stop offset="0" stop-color="#20b038" />
                <stop offset="1" stop-color="#60d66a" />
            </linearGradient>
            <path fill="url(#a)"
                d="M27.875 1190.114l82.211-300.18c-50.719-87.852-77.391-187.523-77.359-289.602.133-319.398 260.078-579.25 579.469-579.25 155.016.07 300.508 60.398 409.898 169.891 109.414 109.492 169.633 255.031 169.57 409.812-.133 319.406-260.094 579.281-579.445 579.281-.023 0 .016 0 0 0 0h-.258c-96.977-.031-192.266-24.375-276.898-70.5l-307.188 80.548z" />
            <path fill-rule="evenodd" clip-rule="evenodd" fill="#FFF"
                d="M462.273 349.294c-11.234-24.977-23.062-25.477-33.75-25.914-8.742-.375-18.75-.352-28.742-.352-10 0-26.25 3.758-39.992 18.766-13.75 15.008-52.5 51.289-52.5 125.078 0 73.797 53.75 145.102 61.242 155.117 7.5 10 103.758 166.266 256.203 226.383 126.695 49.961 152.477 40.023 179.977 37.523s88.734-36.273 101.234-71.297c12.5-35.016 12.5-65.031 8.75-71.305-3.75-6.25-13.75-10-28.75-17.5s-88.734-43.789-102.484-48.789-23.75-7.5-33.75 7.516c-10 15-38.727 48.773-47.477 58.773-8.75 10.023-17.5 11.273-32.5 3.773-15-7.523-63.305-23.344-120.609-74.438-44.586-39.75-74.688-88.844-83.438-103.859-8.75-15-.938-23.125 6.586-30.602 6.734-6.719 15-17.508 22.5-26.266 7.484-8.758 9.984-15.008 14.984-25.008 5-10.016 2.5-18.773-1.25-26.273s-32.898-81.67-46.234-111.326z" />
            <path fill="#FFF"
                d="M1036.898 176.091C923.562 62.677 772.859.185 612.297.114 281.43.114 12.172 269.286 12.039 600.137 12 705.896 39.633 809.13 92.156 900.13L7 1211.067l318.203-83.438c87.672 47.812 186.383 73.008 286.836 73.047h.255.003c330.812 0 600.109-269.219 600.25-600.055.055-160.343-62.328-311.108-175.649-424.53zm-424.601 923.242h-.195c-89.539-.047-177.344-24.086-253.93-69.531l-18.227-10.805-188.828 49.508 50.414-184.039-11.875-18.867c-49.945-79.414-76.312-171.188-76.273-265.422.109-274.992 223.906-498.711 499.102-498.711 133.266.055 258.516 52 352.719 146.266 94.195 94.266 146.031 219.578 145.992 352.852-.118 274.999-223.923 498.749-498.899 498.749z" />
        </svg>
    </a>

    <div class="wpp-overlay" id="wppOverlay"></div>
    <div class="wpp-wrap" id="wppWrap">
        <div class="wpp-box">
            <div class="wpp-hdr">
                <div class="wpp-hdr-av">🌿</div>
                <div class="wpp-hdr-info">
                    <div class="wpp-hdr-name">Casa Voss</div>
                    <div class="wpp-hdr-status">Online</div>
                </div><button class="wpp-hdr-close" id="wppClose" aria-label="Fechar"><svg viewBox="0 0 24 24">
                        <line x1="18" y1="6" x2="6" y2="18" />
                        <line x1="6" y1="6" x2="18" y2="18" />
                    </svg></button>
            </div>
            <div class="wpp-chat" id="wppChat"></div>
            <div class="wpp-bar" id="wppBar"></div>
        </div>
    </div>

    <footer class="bio-footer">
        <p class="bio-footer-copy">© 2026 Casa Voss. Todos os direitos reservados.</p>
        <div class="bio-footer-dev">
            <span class="bio-footer-dev-text">Desenvolvido por:</span>
            <a href="https://dmove.com.br/" target="_blank" rel="noopener noreferrer" class="bio-footer-dev-link"><img
                    class="bio-footer-dev-img"
                    src="https://dmove.com.br/wp-content/webp-express/webp-images/uploads/2024/01/Logotipo.png.webp"
                    alt="DMove" onerror="this.onerror=null;this.style.display='none'" /></a>
        </div>
    </footer>

    <script is:inline src="https://npmcdn.com/flatpickr/dist/flatpickr.min.js"></script>
    

  <script>
    import '../scripts/bio.js';
  </script>
</body>

</html>