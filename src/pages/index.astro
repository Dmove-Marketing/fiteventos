---
// Gerado a partir de: Institucional.html
import Base from '../layouts/Base.astro';
import config from '../../config.json';
import Img from '../components/ui/Img.astro';
import LeadForm from '../components/forms/LeadForm.astro';
import '../styles/institucional.css';
---

<Base
  title="Espaço Fit Eventos – São Paulo"
  description="O espaço ideal para eventos que exigem excelência. 17 ambientes, gastronomia assinada e tecnologia integrada em São Paulo."
  ogImage="/images/og-institucional.jpg"
>
<!-- HEADER -->
<header id="header">
  <div class="container">
    <div class="header-inner">
      <a href="#" class="logo">
        <!-- Light logo (for dark hero bg) -->
        <Img src="logo.fiteventos.webp" alt="Espaço Fit Eventos" class="logo-light" priority />
        <!-- Dark logo (for scrolled white header) -->
        <Img src="logo.fiteventos.webp" alt="Espaço Fit Eventos" class="logo-dark" style="filter:invert(1) sepia(1) saturate(3) hue-rotate(300deg) brightness(0.6);" />
      </a>
      <nav id="nav">
        <a href="#sobre">Espaço</a>
        <a href="#eventos">Eventos</a>
        <a href="#gastronomia">Gastronomia</a>
        <a href="#galeria">Galeria</a>
        <a href="#localizacao">Localização</a>
        <a href="#contato" class="nav-cta">Solicitar orçamento</a>
      </nav>
      <div class="hamburger" id="hamburger">
        <span></span><span></span><span></span>
      </div>
    </div>
  </div>
</header>

<!-- MOBILE MENU OVERLAY (fora do header para evitar conflito com backdrop-filter) -->
<div id="mobile-menu">
  <button id="mobile-close" aria-label="Fechar menu">✕</button>
  <a href="#sobre">Espaço</a>
  <a href="#eventos">Eventos</a>
  <a href="#gastronomia">Gastronomia</a>
  <a href="#galeria">Galeria</a>
  <a href="#localizacao">Localização</a>
  <a href="#contato" class="nav-cta">Solicitar orçamento</a>
</div>

<!-- HERO -->
<section id="hero">
  <video class="hero-bg" autoplay muted loop playsinline preload="auto">
    <source src="/sobre.eventos-corporativos.mp4" type="video/mp4" />
  </video>
  <div class="hero-gradient"></div>
  <div class="hero-accent"></div>
  <div class="container">
    <div class="hero-content">
      <div class="hero-eyebrow">
        <span>São Paulo · Desde 2012</span>
      </div>
      <h1>Um espaço<br>preparado para<br>eventos que<br><em>exigem excelência</em></h1>
      <p>17 ambientes versáteis, gastronomia assinada e tecnologia integrada, para eventos corporativos e sociais que ficam na memória.</p>
    </div>
  </div>
  <div class="hero-stats">
    <div class="container">
      <div class="hero-stats-inner">
        <div class="hero-stat">
          <div class="hero-stat-num"><em>10</em></div>
          <div class="hero-stat-label">Andares</div>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-num"><em>17</em></div>
          <div class="hero-stat-label">Ambientes</div>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-num"><em>+500</em></div>
          <div class="hero-stat-label">Convidados</div>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-num"><em>+10</em></div>
          <div class="hero-stat-label">Anos de experiência</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- SOBRE -->
<section id="sobre">
  <div class="container">
    <div class="sobre-grid">
      <div class="sobre-visual reveal">
        <div class="sobre-img-main">
          <Img src="sobre.institucional.webp" alt="Espaço Fit Eventos – Ambiente" />
        </div>
      </div>
      <div class="sobre-text reveal">
        <span class="label">Sobre o espaço</span>
        <h2>Uma trajetória sólida na realização de<br><em>eventos bem executados.</em></h2>
        <p>O Espaço Fit Eventos nasceu com foco no mercado corporativo e se consolidou atendendo empresas exigentes, que valorizam organização, estrutura e previsibilidade.</p>
        <p>Desde 2012, vem construindo uma operação sólida, com múltiplos ambientes e capacidade para realizar eventos simultâneos com profissionalismo e eficiência, sempre com atendimento validado por grandes empresas.</p>
        <p>Hoje, essa mesma expertise é aplicada na realização de eventos sociais, mantendo o padrão de qualidade que construiu sua reputação ao longo dos anos.</p>
      </div>
    </div>
  </div>
</section>

<!-- ESPAÇOS -->
<section id="espacos">
  <!-- Bloco Corporativo -->
  <div class="espaco-block-label reveal">
    <span class="label">Eventos Corporativos</span>
    <h3>Tudo o que seu evento corporativo precisa,<br><em>em um só lugar</em></h3>
    <p>17 salas versáteis, layouts para até 530 pessoas e tecnologia integrada com painéis de LED<br>e projeção mapeada para experiências presenciais, híbridas ou online.</p>
  </div>
  <div class="mosaic-corp-carousel reveal">
    <button class="carousel-btn carousel-prev" aria-label="Anterior"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg></button>
    <div class="mosaic-corp-carousel-track">
      <div class="mosaic-corp-carousel-slide"><Img src="g-corporativo.institucional01.jpg" alt="Eventos Corporativos" /></div>
      <div class="mosaic-corp-carousel-slide"><Img src="g-corporativo.institucional02.jpg" alt="Eventos Corporativos" /></div>
      <div class="mosaic-corp-carousel-slide"><Img src="g-corporativo.institucional03.jpg" alt="Eventos Corporativos" /></div>
      <div class="mosaic-corp-carousel-slide"><Img src="g-corporativo.institucional04.jpg" alt="Eventos Corporativos" /></div>
      <div class="mosaic-corp-carousel-slide"><Img src="g-corporativo.institucional05.jpg" alt="Eventos Corporativos" /></div>
      <div class="mosaic-corp-carousel-slide"><Img src="g-corporativo.institucional06.jpg" alt="Eventos Corporativos" /></div>
      <div class="mosaic-corp-carousel-slide"><Img src="g-corporativo.institucional07.jpg" alt="Eventos Corporativos" /></div>
      <div class="mosaic-corp-carousel-slide"><Img src="g-corporativo.institucional08.jpg" alt="Eventos Corporativos" /></div>
      <div class="mosaic-corp-carousel-slide"><Img src="g-corporativo.institucional09.jpg" alt="Eventos Corporativos" /></div>
      <div class="mosaic-corp-carousel-slide"><Img src="g-corporativo.institucional10.jpg" alt="Eventos Corporativos" /></div>
      <div class="mosaic-corp-carousel-slide"><Img src="g-corporativo.institucional11.jpg" alt="Eventos Corporativos" /></div>
    </div>
    <button class="carousel-btn carousel-next" aria-label="Próximo"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></button>
  </div>
  <div class="espaco-cta-row">
    <a href="https://lp.espacofiteventos.com.br/eventos-corporativos/" class="btn btn-outline">Saiba mais sobre eventos corporativos
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>

  <!-- Bloco Social -->
  <div class="espaco-block-label reveal" style="margin-top: 72px;">
    <span class="label">Eventos Sociais</span>
    <h3>Seu evento social em<br><em>um espaço surpreendente</em></h3>
    <p>Celebre casamentos, festas de 15 anos e aniversários com a mesma excelência,<br>estrutura e cuidado que consolidam o Espaço FIT como referência no mercado.</p>
  </div>
  <div class="sociais-carousel reveal">
    <button class="carousel-btn carousel-prev" aria-label="Anterior"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg></button>
    <div class="sociais-carousel-track">
      <div class="sociais-carousel-slide"><Img src="sociais.institucional01_resultado.webp" alt="Eventos Sociais" /></div>
      <div class="sociais-carousel-slide"><Img src="sociais.institucional02_resultado.webp" alt="Eventos Sociais" /></div>
      <div class="sociais-carousel-slide"><Img src="sociais.institucional03_resultado.webp" alt="Eventos Sociais" /></div>
      <div class="sociais-carousel-slide"><Img src="sociais.institucional04_resultado.webp" alt="Eventos Sociais" /></div>
      <div class="sociais-carousel-slide"><Img src="sociais.institucional05_resultado.webp" alt="Eventos Sociais" /></div>
      <div class="sociais-carousel-slide"><Img src="sociais.institucional06_resultado.webp" alt="Eventos Sociais" /></div>
      <div class="sociais-carousel-slide"><Img src="sociais.institucional07_resultado.webp" alt="Eventos Sociais" /></div>
      <div class="sociais-carousel-slide"><Img src="sociais.institucional08_resultado.webp" alt="Eventos Sociais" /></div>
      <div class="sociais-carousel-slide"><Img src="sociais.institucional09_resultado.webp" alt="Eventos Sociais" /></div>
    </div>
    <button class="carousel-btn carousel-next" aria-label="Próximo"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></button>
  </div>
  <div class="espaco-cta-row">
    <a href="https://lp.espacofiteventos.com.br/debutantes/" class="btn btn-outline">Saiba mais sobre eventos sociais
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>
</section>

<!-- ESTRUTURA -->
<section id="estrutura">
  <div class="container">
    <div class="estrutura-inner">
      <div class="estrutura-head reveal">
        <span class="label" style="color:rgba(255,255,255,0.6)">Infraestrutura</span>
        <h2>Estrutura completa para <em>eventos de todos os formatos</em></h2>
      </div>
      <div class="estrutura-grid reveal">
        <div class="estrutura-item">
          <div class="estrutura-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
          </div>
          <h3>Mobiliário completo</h3>
        </div>
        <div class="estrutura-item">
          <div class="estrutura-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
          </div>
          <h3>Equipamentos de som, luz e tecnologia</h3>
        </div>
        <div class="estrutura-item">
          <div class="estrutura-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <h3>10 andares com múltiplos ambientes</h3>
        </div>
        <div class="estrutura-item">
          <div class="estrutura-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
          </div>
          <h3>17 salas versáteis</h3>
        </div>
        <div class="estrutura-item">
          <div class="estrutura-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          </div>
          <h3>Espaços adaptáveis para diferentes públicos</h3>
        </div>
        <div class="estrutura-item">
          <div class="estrutura-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <h3>Operação para eventos simultâneos</h3>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- TIPOS DE EVENTOS -->
<section id="eventos">
  <div class="eventos-header reveal">
    <span class="label">Versatilidade</span>
    <h2>Um espaço preparado para atender<br><em>múltiplos formatos com eficiência</em></h2>
    <p>Todos os formatos contam com suporte completo, da estrutura à execução do evento.</p>
  </div>
  <div class="eventos-cards reveal">
      <div class="evento-card">
        <div class="evento-card-img">
          <Img src="debutante.atualida-img.webp" alt="Festa de 15 anos" />
        </div>
        <div class="evento-card-body">
          <div class="evento-num">01</div>
          <h3>Festa de 15 anos</h3>
          <a href="https://lp.espacofiteventos.com.br/debutantes/" class="evento-link">
            Ver detalhes
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
      <div class="evento-card">
        <div class="evento-card-img">
          <Img src="casamento-atualizada.webp" alt="Casamentos" />
        </div>
        <div class="evento-card-body">
          <div class="evento-num">02</div>
          <h3>Casamentos</h3>
        </div>
      </div>
      <div class="evento-card">
        <div class="evento-card-img">
          <Img src="aniversario-atualizada.webp" alt="Aniversários" />
        </div>
        <div class="evento-card-body">
          <div class="evento-num">03</div>
          <h3>Aniversários</h3>
        </div>
      </div>
      <div class="evento-card">
        <div class="evento-card-img">
          <Img src="corporativos-atualizada.webp" alt="Corporativos" />
        </div>
        <div class="evento-card-body">
          <div class="evento-num">04</div>
          <h3>Corporativos</h3>
          <a href="https://lp.espacofiteventos.com.br/eventos-corporativos/" class="evento-link">
            Ver detalhes
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
  </div>
</section>

<!-- GASTRONOMIA -->
<section id="gastronomia">
  <div class="container">
    <div class="gastro-grid">
      <div class="gastro-visual reveal">
        <div class="gastro-img">
          <div class="gastro-slides">
            <div class="gastro-slide active"><Img src="gastronomia.institucional01.webp" alt="Gastronomia Espaço Fit" priority /></div>
            <div class="gastro-slide"><Img src="gastronomia.institucional02.webp" alt="Gastronomia Espaço Fit" /></div>
            <div class="gastro-slide"><Img src="gastronomia.institucional03.webp" alt="Gastronomia Espaço Fit" /></div>
            <div class="gastro-slide"><Img src="gastronomia.institucional04.webp" alt="Gastronomia Espaço Fit" /></div>
            <div class="gastro-slide"><Img src="gastronomia.institucional05.webp" alt="Gastronomia Espaço Fit" /></div>
            <div class="gastro-slide"><Img src="gastronomia.institucional06.webp" alt="Gastronomia Espaço Fit" /></div>
            <div class="gastro-slide"><Img src="gastronomia.institucional07.webp" alt="Gastronomia Espaço Fit" /></div>
            <div class="gastro-slide"><Img src="gastronomia.institucional08.webp" alt="Gastronomia Espaço Fit" /></div>
            <div class="gastro-slide"><Img src="gastronomia.institucional09.webp" alt="Gastronomia Espaço Fit" /></div>
            <div class="gastro-slide"><Img src="gastronomia.institucional10.webp" alt="Gastronomia Espaço Fit" /></div>
            <div class="gastro-slide"><Img src="gastronomia.institucional11.webp" alt="Gastronomia Espaço Fit" /></div>
            <div class="gastro-slide"><Img src="gastronomia.institucional12.webp" alt="Gastronomia Espaço Fit" /></div>
            <div class="gastro-slide"><Img src="gastronomia.institucional13.webp" alt="Gastronomia Espaço Fit" /></div>
            <div class="gastro-slide"><Img src="gastronomia.institucional14.webp" alt="Gastronomia Espaço Fit" /></div>
            <div class="gastro-slide"><Img src="gastronomia.institucional15.webp" alt="Gastronomia Espaço Fit" /></div>
            <div class="gastro-slide"><Img src="gastronomia.institucional16.webp" alt="Gastronomia Espaço Fit" /></div>
          </div>
        </div>
        <div class="gastro-chef-badge">
          <div class="sub">Assinado por</div>
          <div class="name">Chef Dalton Rangel</div>
        </div>
      </div>
      <div class="gastro-text reveal">
        <span class="label">Gastronomia</span>
        <h2>Gastronomia que acompanha <em>a experiência do seu evento</em></h2>
        <p>Assinada pelo premiado <b>Chef Dalton Rangel</b>, a gastronomia é um dos destaques do Espaço Fit, com opções pensadas para diferentes tipos de evento, mantendo qualidade, consistência e integração total com a dinâmica da experiência.</p>
        <p>Incluindo <b>cardápios com opções vegetarianas e veganas, adaptados ao perfil do evento e dos convidados</b>.</p>
        <div class="gastro-menu">
          <div class="gastro-menu-item">Coffee break</div>
          <div class="gastro-menu-item">Almoço corporativo</div>
          <div class="gastro-menu-item">Finger foods</div>
          <div class="gastro-menu-item">Jantar completo</div>
          <div class="gastro-menu-item">Menu vegano</div>
          <div class="gastro-menu-item">Menu vegetariano</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- GALERIA -->
<section id="galeria">
  <div class="galeria-header reveal">
    <span class="label">Galeria</span>
    <h2>Um espaço, diversas formas de<br><em>realizar seu evento</em></h2>
  </div>
  <div class="galeria-mosaic-wrap">
  <div class="galeria-mosaic reveal">
    <div class="gal-item"><Img src="galeria-pr.institucional06.webp" alt="Galeria Espaço Fit Eventos" /></div>
    <div class="gal-item"><Img src="galeria-pr.institucional19.webp" alt="Galeria Espaço Fit Eventos" /></div>
    <div class="gal-item"><Img src="galeria-pr.institucional08.webp" alt="Galeria Espaço Fit Eventos" /></div>
    <div class="gal-item"><Img src="galeria-pr.institucional20.webp" alt="Galeria Espaço Fit Eventos" /></div>
    <div class="gal-item"><Img src="galeria-pr.institucional01.webp" alt="Galeria Espaço Fit Eventos" /></div>
    <div class="gal-item"><Img src="galeria-pr.institucional09.webp" alt="Galeria Espaço Fit Eventos" /></div>
    <div class="gal-item"><Img src="galeria-pr.institucional21.webp" alt="Galeria Espaço Fit Eventos" /></div>
    <div class="gal-item"><Img src="galeria-pr.institucional03.webp" alt="Galeria Espaço Fit Eventos" /></div>
    <div class="gal-item"><Img src="galeria-pr.institucional05.webp" alt="Galeria Espaço Fit Eventos" /></div>
    <div class="gal-item"><Img src="galeria-pr.institucional12.webp" alt="Galeria Espaço Fit Eventos" /></div>
    <div class="gal-item"><Img src="galeria-pr.institucional14.webp" alt="Galeria Espaço Fit Eventos" /></div>
    <div class="gal-item"><Img src="galeria-pr.institucional07.webp" alt="Galeria Espaço Fit Eventos" /></div>
    <div class="gal-item"><Img src="galeria-pr.institucional22.webp" alt="Galeria Espaço Fit Eventos" /></div>
    <div class="gal-item"><Img src="galeria-pr.institucional04.webp" alt="Galeria Espaço Fit Eventos" /></div>
    <div class="gal-item"><Img src="galeria-pr.institucional17.webp" alt="Galeria Espaço Fit Eventos" /></div>
    <div class="gal-item"><Img src="galeria-pr.institucional02.webp" alt="Galeria Espaço Fit Eventos" /></div>
    <div class="gal-item"><Img src="galeria-pr.institucional13.webp" alt="Galeria Espaço Fit Eventos" /></div>
    <div class="gal-item"><Img src="galeria-pr.institucional10.webp" alt="Galeria Espaço Fit Eventos" /></div>
    <div class="gal-item"><Img src="galeria-pr.institucional11.webp" alt="Galeria Espaço Fit Eventos" /></div>
    <div class="gal-item"><Img src="galeria-pr.institucional15.webp" alt="Galeria Espaço Fit Eventos" /></div>
  </div>
  </div>
  <div class="galeria-mobile-carousel">
    <button class="carousel-btn carousel-prev" aria-label="Anterior"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg></button>
    <div class="galeria-mobile-carousel-track">
      <div class="galeria-mobile-carousel-slide"><Img src="galeria-pr.institucional06.webp" alt="Galeria Espaço Fit Eventos" /></div>
      <div class="galeria-mobile-carousel-slide"><Img src="galeria-pr.institucional19.webp" alt="Galeria Espaço Fit Eventos" /></div>
      <div class="galeria-mobile-carousel-slide"><Img src="galeria-pr.institucional08.webp" alt="Galeria Espaço Fit Eventos" /></div>
      <div class="galeria-mobile-carousel-slide"><Img src="galeria-pr.institucional20.webp" alt="Galeria Espaço Fit Eventos" /></div>
      <div class="galeria-mobile-carousel-slide"><Img src="galeria-pr.institucional01.webp" alt="Galeria Espaço Fit Eventos" /></div>
      <div class="galeria-mobile-carousel-slide"><Img src="galeria-pr.institucional09.webp" alt="Galeria Espaço Fit Eventos" /></div>
      <div class="galeria-mobile-carousel-slide"><Img src="galeria-pr.institucional21.webp" alt="Galeria Espaço Fit Eventos" /></div>
