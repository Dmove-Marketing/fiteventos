            <a href="/servicos/" class="btn btn-outline">
              Saiba Mais
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
            </a>
          </div>
        </div>
        <div class="servico-card">
          <div class="servico-img">
            <Img
              src="Sala_Design.eventos-corporativos05.webp"
              alt="Mobiliário"
            />
          </div>
          <div class="servico-body">
            <h3>Mobiliário</h3>
            <p>Conforto e funcionalidade em cada configuração</p>
            <a href="/servicos/" class="btn btn-outline">
              Saiba Mais
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
            </a>
          </div>
        </div>
        <div class="servico-card">
          <div class="servico-img">
            <Img
              src="gastronomia.institucional01.webp"
              alt="Gastronomia"
            />
          </div>
          <div class="servico-body">
            <h3>Gastronomia</h3>
            <p>Cardápios assinados pelo premiado Chef Dalton Rangel</p>
            <a href="/servicos/" class="btn btn-outline">
              Saiba Mais
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PARCEIROS -->
  <section id="parceiros">
    <div class="parceiros-head reveal">
      <span class="label">Parceiros</span>
      <h2>Seu evento no mesmo <em style="font-style:normal; font-weight:700; color:var(--rose)">Espaço de grandes empresas</em></h2>
