---
// src/pages/index.astro
// Página exemplo do template — substituir pelo conteúdo do cliente
import Base from '../layouts/Base.astro';
---

<Base
  title="Template | Dmove Sites"
  description="Template base para projetos Dmove Sites"
>
  <section class="hero">
    <div class="hero-glow"></div>
    <div class="container hero-content">
      <span class="badge" data-animate="fade-up">Template Ativo</span>
      <h1 data-animate="fade-up" data-delay="0.1">
        Dmove Sites <span class="gradient-text">Template Base</span>
      </h1>
      <p data-animate="fade-up" data-delay="0.2">
        Este é o template base para novos projetos. Copie esta pasta para criar o projeto do cliente.
      </p>
      <div class="hero-actions" data-animate="fade-up" data-delay="0.3">
        <a href="#" class="btn btn-primary" data-cta="hero-start">Começar projeto →</a>
        <a href="#" class="btn btn-ghost">Ver documentação</a>
      </div>
    </div>
  </section>

  <script>
    import { initSmoothScroll } from '../scripts/smooth-scroll';
    import { initScrollAnimations, initScrollDepthTracking, initCTATracking } from '../scripts/animations';

    function init() {
      initSmoothScroll();
      initScrollAnimations();
      initScrollDepthTracking();
      initCTATracking();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  </script>
</Base>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 30%, rgba(99, 102, 241, 0.12), transparent 60%);
    z-index: 0;
  }

  .hero-content {
    text-align: center;
    max-width: 700px;
    position: relative;
    z-index: 1;
  }

  .badge {
    display: inline-block;
    padding: 6px 16px;
    background: rgba(99, 102, 241, 0.12);
    border: 1px solid rgba(99, 102, 241, 0.25);
    border-radius: var(--radius-full);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-primary-light);
    margin-bottom: var(--space-lg);
  }

  .hero-content h1 {
    margin-bottom: var(--space-lg);
  }

  .hero-content p {
    font-size: 1.15rem;
    max-width: 520px;
    margin: 0 auto var(--space-xl);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
