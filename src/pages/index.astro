---
import Base from "../layouts/Base.astro";
import config from "../../config.json";
import Img from "../components/ui/Img.astro";
import LeadForm from "../components/forms/LeadForm.astro";
import "../styles/institucional.css";
---

<Base
  title="Espaço Fit Eventos – São Paulo"
  description="O espaço ideal para eventos que exigem excelência. 16 ambientes, gastronomia assinada e tecnologia integrada em São Paulo."
  ogImage="/images/novo_logo.png"
>
  <!-- HEADER -->
  <header id="header">
    <div class="container">
      <div class="header-inner">
        <a href="#hero" class="logo">
          <Img
            src="logo.fiteventos.webp"
            alt="Espaço Fit Eventos"
            class="logo-img"
            priority
          />
        </a>
        <nav id="nav">
          <a href="/">Home</a>
          <a href="/empresa/">Empresa</a>
          <a href="/eventos/">Eventos</a>
          <a href="/estrutura/">Estrutura</a>
          <a href="/servicos/">Serviços</a>
          <a href="/faq/">FAQ</a>
          <a href="#contato" class="nav-cta">Solicitar orçamento</a>
        </nav>
        <div class="hamburger" id="hamburger">
          <span></span><span></span><span></span>
        </div>
      </div>
    </div>
  </header>

  <!-- MOBILE MENU OVERLAY -->
  <div id="mobile-menu">
    <button id="mobile-close" aria-label="Fechar menu">✕</button>
    <a href="/">Home</a>
    <a href="/empresa/">Empresa</a>
    <a href="/eventos/">Eventos</a>
    <a href="/estrutura/">Estrutura</a>
    <a href="/servicos/">Serviços</a>
    <a href="/faq/">FAQ</a>
    <a href="#contato" class="nav-cta">Solicitar orçamento</a>
  </div>

  <!-- HERO -->
  <section id="hero">
    <div class="hero-slides">
      <div class="hero-slide active">
        <Img src="galeria-pr.institucional08.webp" alt="" class="hero-slide-img" priority />
      </div>
      <div class="hero-slide">
        <Img src="galeria-pr.institucional19.webp" alt="" class="hero-slide-img" />
      </div>
      <div class="hero-slide">
        <Img src="corporativos-atualizada.webp" alt="" class="hero-slide-img" />
      </div>
      <div class="hero-slide">
        <Img src="galeria-pr.institucional06.webp" alt="" class="hero-slide-img" />
      </div>
    </div>
    <div class="hero-gradient"></div>
    <div class="hero-accent"></div>
    <div class="container">
      <div class="hero-content">
        <div class="hero-eyebrow">
          <span>São Paulo · Desde 2012</span>
        </div>
        <h2>
          Um espaço preparado para<br />eventos que <em>exigem excelência</em>
        </h2>
        <div class="hero-actions">
          <a href="/eventos-corporativos/" class="btn btn-outline-white">
            Eventos Corporativos
          </a>
          <a href="/eventos/" class="btn btn-outline-white">
            Eventos Sociais
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- AUTORIDADE -->
  <section id="autoridade">
    <div class="container">
      <div class="autoridade-inner">
        <div class="autoridade-item">
          <span class="autoridade-num">
            <em class="count-up" data-target="16" data-suffix="">0</em>
          </span>
          <span class="autoridade-label">Ambientes</span>
        </div>
        <div class="autoridade-sep"></div>
        <div class="autoridade-item">
          <span class="autoridade-num">
            <em class="count-up" data-target="10" data-prefix="+" data-suffix="">0</em>
          </span>
          <span class="autoridade-label">Anos de experiência</span>
        </div>
        <div class="autoridade-sep"></div>
        <div class="autoridade-item">
          <span class="autoridade-label autoridade-label-large">Serviços<br />completos</span>
        </div>
      </div>
    </div>
  </section>

  <!-- EMPRESA -->
  <section id="empresa">
    <div class="container">
      <div class="empresa-grid">
        <div class="empresa-visual reveal">
          <div class="empresa-video-wrap">
            <video autoplay muted loop playsinline>
              <source src="/sobre.eventos-corporativos.mp4" type="video/mp4" />
            </video>
          </div>
        </div>
        <div class="empresa-text reveal">
          <span class="label">Sobre o espaço</span>
          <h2>
            Uma trajetória sólida na realização de<br />
            <em style="font-style:normal; color:var(--rose)">eventos bem executados</em>
          </h2>
          <p>
            Desde 2012, o Espaço Fit Eventos transforma encontros corporativos e
            sociais em experiências bem executadas, unindo estrutura, tecnologia e
            atendimento de excelência em uma operação preparada para os mais
            diversos formatos de evento.
          </p>
          <a href="/empresa" class="btn btn-primary">
            Saiba Mais
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- EVENTOS -->
  <section id="eventos">
    <div class="container">
      <div class="eventos-header reveal">
        <span class="label">Versatilidade</span>
        <h2>
          Um espaço preparado para atender<br /><em
            >múltiplos formatos com eficiência</em
          >
        </h2>
      </div>
    </div>
    <div class="container">
    <div class="eventos-cards reveal">
      <div class="evento-card">
        <div class="evento-card-img">
          <Img src="debutante.atualida-img.webp" alt="Festa de 15 anos" />
        </div>
        <div class="evento-card-body">
          <div class="evento-num">01</div>
          <h3>Festa de 15 anos</h3>
          <a
            href="https://lp.espacofiteventos.com.br/debutantes/"
            class="evento-link"
          >
            Ver detalhes
            <svg
              width="12"
              height="12"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
            >
          </a>
        </div>
      </div>
      <div class="evento-card">
        <div class="evento-card-img">
          <Img src="casamento-atualizada.webp" alt="Casamentos" />
        </div>
        <div class="evento-card-body">
          <div class="evento-num">02</div>
          <h3>Casamentos</h3>
          <a href="#contato" class="evento-link">
            Ver detalhes
            <svg
              width="12"
              height="12"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
            >
          </a>
        </div>
      </div>
      <div class="evento-card">
        <div class="evento-card-img">
          <Img src="aniversario-atualizada.webp" alt="Aniversários" />
        </div>
        <div class="evento-card-body">
          <div class="evento-num">03</div>
          <h3>Aniversários</h3>
          <a href="#contato" class="evento-link">
            Ver detalhes
            <svg
              width="12"
              height="12"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
            >
          </a>
        </div>
      </div>
      <div class="evento-card">
        <div class="evento-card-img">
          <Img src="corporativos-atualizada.webp" alt="Eventos Corporativos" />
        </div>
        <div class="evento-card-body">
          <div class="evento-num">04</div>
          <h3>Corporativos</h3>
          <a
            href="https://lp.espacofiteventos.com.br/eventos-corporativos/"
            class="evento-link"
          >
            Ver detalhes
            <svg
              width="12"
              height="12"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
            >
          </a>
        </div>
      </div>
    </div>
    </div>
    <div class="container">
      <div class="eventos-cta reveal">
        <a href="#contato" class="btn btn-primary">
          Solicitar orçamento
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- SERVIÇOS -->
  <section id="servicos">
    <div class="container">
      <div class="servicos-header reveal">
        <span class="label">Estrutura &amp; Serviços</span>
        <h2>
          Estrutura completa para <em>simplificar a organização</em> e elevar a
          experiência dos convidados
        </h2>
      </div>
      <div class="servicos-grid reveal">
        <div class="servico-card">
          <div class="servico-img">
            <Img
              src="Sala_Design.eventos-corporativos01.webp"
              alt="Espaços"
            />
          </div>
          <div class="servico-body">
            <h3>Espaços</h3>
            <p>
              Ambientes preparados para receber de 30 a 530 convidados com
              excelência
            </p>
            <a href="/estrutura/" class="btn btn-outline">
              Saiba Mais
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
            </a>
          </div>
        </div>
        <div class="servico-card">
          <div class="servico-img">
            <Img
              src="Audiovisual.eventos-corporativos.webp"
              alt="Tecnologia"
            />
          </div>
          <div class="servico-body">
            <h3>Tecnologia</h3>
            <p>
              Equipamentos e soluções para eventos presenciais, híbridos e online
