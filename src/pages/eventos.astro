---
import Base from "../layouts/Base.astro";
import config from "../../config.json";
import Img from "../components/ui/Img.astro";
import LeadForm from "../components/forms/LeadForm.astro";
import "../styles/institucional.css";
---

<Base
  title="Eventos – Espaço Fit Eventos"
  description="Do corporativo ao social, o Espaço Fit Eventos oferece estrutura completa para múltiplos formatos de evento em São Paulo."
  ogImage="/images/novo_logo.png"
>
  <!-- HEADER -->
  <header id="header">
    <div class="container">
      <div class="header-inner">
        <a href="/" class="logo">
          <Img
            src="logo.fiteventos.webp"
            alt="Espaço Fit Eventos"
            class="logo-img"
            priority
          />
        </a>
        <nav id="nav">
          <a href="/">Home</a>
          <a href="/empresa/">Empresa</a>
          <a href="/eventos/" class="nav-active">Eventos</a>
          <a href="/estrutura/">Estrutura</a>
          <a href="/servicos/">Serviços</a>
          <a href="/faq/">FAQ</a>
          <a href="#contato" class="nav-cta">Solicitar orçamento</a>
        </nav>
        <div class="hamburger" id="hamburger">
          <span></span><span></span><span></span>
        </div>
      </div>
    </div>
  </header>

  <!-- MOBILE MENU OVERLAY -->
  <div id="mobile-menu">
    <button id="mobile-close" aria-label="Fechar menu">✕</button>
    <a href="/">Home</a>
    <a href="/empresa/">Empresa</a>
    <a href="/eventos/">Eventos</a>
    <a href="/estrutura/">Estrutura</a>
    <a href="/servicos/">Serviços</a>
    <a href="/faq/">FAQ</a>
    <a href="#contato" class="nav-cta">Solicitar orçamento</a>
  </div>

  <!-- HERO -->
  <section id="hero">
    <div class="hero-slides">
      <div class="hero-slide active">
        <Img src="galeria-pr.institucional08.webp" alt="" class="hero-slide-img" priority />
      </div>
      <div class="hero-slide">
        <Img src="corporativos-atualizada.webp" alt="" class="hero-slide-img" />
      </div>
      <div class="hero-slide">
        <Img src="casamento-atualizada.webp" alt="" class="hero-slide-img" />
      </div>
      <div class="hero-slide">
        <Img src="galeria-pr.institucional19.webp" alt="" class="hero-slide-img" />
      </div>
    </div>
    <div class="hero-gradient"></div>
    <div class="hero-accent"></div>
    <div class="container">
      <div class="hero-content">
        <div class="hero-eyebrow">
          <span>São Paulo · Desde 2012</span>
        </div>
        <h1>
          Um espaço preparado para receber<br /><em>diferentes histórias</em>
        </h1>
        <div class="hero-actions">
          <a href="#corporativos" class="btn btn-outline-white">
            Ver eventos
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- EVENTOS CORPORATIVOS -->
  <section id="corporativos" class="ev-section">
    <div class="container">
      <div class="ev-grid">
        <div class="ev-text reveal">
          <span class="label">Corporativos</span>
          <h2>Eventos corporativos com <em>eficiência e profissionalismo</em></h2>
          <p>
            Com 16 salas versáteis, tecnologia integrada, mobiliário completo e uma operação
            preparada para eventos simultâneos, oferecemos a flexibilidade e o suporte
            necessários para que cada evento aconteça com excelência, do planejamento à
            execução.
          </p>
          <a href="#contato" class="btn btn-primary">
            Solicitar orçamento
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
          </a>
        </div>
        <div class="ev-carousel reveal" id="corp-carousel">
          <button class="ev-carousel-btn ev-carousel-prev" aria-label="Anterior">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
          </button>
          <div class="ev-carousel-track">
            <div class="ev-carousel-slide"><Img src="01-espaco-para-locacao-auditorio-espaco-fit-eventos-1.jpg" alt="Auditório Espaço Fit Eventos" /></div>
            <div class="ev-carousel-slide"><Img src="01-sala-high-tech-1.jpg" alt="Sala High Tech" /></div>
            <div class="ev-carousel-slide"><Img src="02-sala-vip-1.jpg" alt="Sala VIP" /></div>
            <div class="ev-carousel-slide"><Img src="03-sala-painel-led.jpg" alt="Sala Painel LED" /></div>
            <div class="ev-carousel-slide"><Img src="04-sala-high-tech-1.jpg" alt="Sala High Tech" /></div>
            <div class="ev-carousel-slide"><Img src="05-sala-streaming.jpg" alt="Sala Streaming" /></div>
            <div class="ev-carousel-slide"><Img src="06-sala-design-thinking-1.jpg" alt="Sala Design Thinking" /></div>
            <div class="ev-carousel-slide"><Img src="07-salas-modernas-1.jpg" alt="Salas Modernas" /></div>
            <div class="ev-carousel-slide"><Img src="08-sala-530-pax.jpg" alt="Sala 530 pessoas" /></div>
            <div class="ev-carousel-slide"><Img src="10-sala-reuniao.jpg" alt="Sala de Reunião" /></div>
            <div class="ev-carousel-slide"><Img src="14-sala-mapeada.jpg" alt="Sala Mapeada" /></div>
          </div>
          <button class="ev-carousel-btn ev-carousel-next" aria-label="Próximo">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- EVENTOS SOCIAIS -->
  <section id="sociais" class="ev-section ev-section-alt">
    <div class="container">
      <div class="ev-grid">
        <div class="ev-carousel reveal" id="social-carousel">
          <button class="ev-carousel-btn ev-carousel-prev" aria-label="Anterior">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
          </button>
          <div class="ev-carousel-track">
            <div class="ev-carousel-slide"><Img src="1MKOF_1545_DSC08177.jpg" alt="Eventos Sociais" /></div>
            <div class="ev-carousel-slide"><Img src="2DECOR_1068_RICK6221-Copia.jpg" alt="Decoração de eventos" /></div>
            <div class="ev-carousel-slide"><Img src="2DECOR_1074_RICK6230.jpg" alt="Decoração de eventos" /></div>
            <div class="ev-carousel-slide"><Img src="2DECOR_1570_DSC08212.jpg" alt="Eventos sociais" /></div>
            <div class="ev-carousel-slide"><Img src="2DECOR_1571_DSC08215.jpg" alt="Eventos sociais" /></div>
            <div class="ev-carousel-slide"><Img src="espaco-confraternizacao-fim-de-ano-empresa-sp-07.jpg" alt="Confraternização" /></div>
          </div>
          <button class="ev-carousel-btn ev-carousel-next" aria-label="Próximo">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
          </button>
        </div>
        <div class="ev-text reveal">
          <span class="label">Sociais</span>
          <h2>Celebrações que merecem um <em>cenário à altura</em></h2>
          <p>
            Casamentos, festas de 15 anos, aniversários e momentos especiais ganham ainda
            mais significado em um espaço preparado para receber convidados com conforto,
            sofisticação e atenção aos detalhes. Cada celebração é planejada para refletir
            a personalidade de quem a realiza.
          </p>
          <a href="#contato" class="btn btn-primary">
            Solicitar orçamento
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CAPACIDADE -->
  <section id="capacidade">
    <div class="container">
      <div class="capacidade-header reveal">
        <span class="label">Capacidade</span>
        <h2>Soluções inteligentes para <em>cada formato de evento</em></h2>
      </div>
    </div>
    <div class="capacidade-img reveal">
      <Img src="tabela-de-capacidade-das-salas-para-eventos-corporativos-espaco-fit-eventos.webp" alt="Tabela de capacidade das salas – Espaço Fit Eventos" />
    </div>
  </section>

  <!-- GALERIA -->
  <section id="galeria">
    <div class="parceiros-head reveal">
      <span class="label">Galeria</span>
      <h2>Estrutura, experiência e um grupo que <em>respira excelência</em></h2>
    </div>
    <div class="parceiros-grid reveal">
      <div class="parceiro-item"><img src="/logos/1.webp" alt="Parceiro" /></div>
      <div class="parceiro-item"><img src="/logos/2.webp" alt="Parceiro" /></div>
      <div class="parceiro-item"><img src="/logos/3.webp" alt="Parceiro" /></div>
      <div class="parceiro-item"><img src="/logos/4.webp" alt="Parceiro" /></div>
      <div class="parceiro-item"><img src="/logos/5.webp" alt="Parceiro" /></div>
      <div class="parceiro-item"><img src="/logos/6.webp" alt="Parceiro" /></div>
      <div class="parceiro-item"><img src="/logos/7.webp" alt="Parceiro" /></div>
      <div class="parceiro-item"><img src="/logos/8.webp" alt="Parceiro" /></div>
      <div class="parceiro-item"><img src="/logos/9.webp" alt="Parceiro" /></div>
      <div class="parceiro-item"><img src="/logos/10.webp" alt="Parceiro" /></div>
      <div class="parceiro-item"><img src="/logos/11.webp" alt="Parceiro" /></div>
      <div class="parceiro-item"><img src="/logos/12.webp" alt="Parceiro" /></div>
      <div class="parceiro-item"><img src="/logos/13.webp" alt="Parceiro" /></div>
      <div class="parceiro-item"><img src="/logos/14.webp" alt="Parceiro" /></div>
      <div class="parceiro-item"><img src="/logos/15.webp" alt="Parceiro" /></div>
    </div>
  </section>

  <!-- CONTATO -->
  <section id="contato">
    <div class="contato-inner">
      <div class="contato-img">
        <Img src="DSCF4322.jpg" alt="Espaço Fit Eventos" />
      </div>
      <div class="contato-form-side">
        <div class="contato-form-content reveal">
          <span class="label" style="color:var(--rose-light)">Próximo passo</span>
          <h2>
            Planeje seu evento com <em style="color:var(--rose)">quem entende do assunto</em>
          </h2>
          <p>
            Fale com nossa equipe e conheça as possibilidades de espaço,
            estrutura e serviços disponíveis para o seu evento.
          </p>
          <div class="form-box">
            <LeadForm
              formId="lead-form-eventos"
              project={config.project_slug}
              submitUrl={config.forms["lead-form"].webhooks[0]}
              redirectUrl={config.forms["lead-form"].redirect_on_success}
              submitText="Solicitar orçamento"
              honeypot
              fields={[
                {
                  name: "nome",
                  type: "text",
                  placeholder: "Seu nome completo",
                  required: true,
                },
                {
                  type: "row",
                  fields: [
                    {
                      name: "telefone",
                      type: "tel",
                      placeholder: "(11) 9 0000-0000",
                      required: true,
                    },
                    {
                      name: "email",
                      type: "email",
                      placeholder: "seu@email.com",
                      required: true,
                    },
                  ],
                },
                {
                  type: "row",
                  fields: [
                    {
                      name: "tipo",
                      type: "select",
                      required: true,
                      options: [
                        { value: "", label: "Tipo de evento...", disabled: true, selected: true },
                        { value: "Aniversário", label: "Aniversário" },
                        { value: "Aniversário debutante", label: "Aniversário debutante" },
                        { value: "Bodas", label: "Bodas" },
                        { value: "Casamento", label: "Casamento" },
                        { value: "Mini Wedding", label: "Mini Wedding" },
                        { value: "Confraternização corporativa", label: "Confraternização corporativa" },
                        { value: "Confraternização social", label: "Confraternização social" },
                        { value: "Corporativo", label: "Corporativo" },
                        { value: "Festas Judaicas", label: "Festas Judaicas" },
                        { value: "Bar Mitzvah", label: "Bar Mitzvah" },
                        { value: "Bat Mitzvah", label: "Bat Mitzvah" },
                        { value: "Formatura", label: "Formatura" },
                        { value: "Happy Hour", label: "Happy Hour" },
                        { value: "Masterclass e Palestras", label: "Masterclass e Palestras" },
                        { value: "Mentorias e Treinamentos", label: "Mentorias e Treinamentos" },
                        { value: "Offsite corporativo", label: "Offsite corporativo" },
                        { value: "Shows e Festivais", label: "Shows e Festivais" },
                        { value: "Workshops, Conferências e Seminários", label: "Workshops, Conferências e Seminários" },
                        { value: "Outros", label: "Outros" },
                      ],
                    },
                    {
                      name: "data",
                      type: "text",
                      placeholder: "Data do evento",
                      required: true,
                      readonly: true,
                      flatpickr: true,
                    },
                  ],
                },
                {
                  name: "convidados",
                  type: "number",
                  placeholder: "Nº de convidados",
                  required: true,
                },
                {
                  name: "mensagem",
                  type: "textarea",
                  placeholder: "Detalhes adicionais (não obrigatório)",
                  required: false,
                  rows: 4,
                },
                { name: "fonte", type: "hidden", value: "Landing page/eventos" },
              ]}
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- LOCALIZAÇÃO -->
  <section id="localizacao">
    <div class="container">
      <div class="loc-grid">
        <div class="loc-text reveal">
          <span class="label">Localização</span>
          <h2>Localização <em>prática e acessível</em></h2>
          <p>
            Um ponto estratégico que facilita a chegada de convidados e a
            operação do evento do início ao fim.
          </p>
          <div class="loc-details">
            <div class="loc-detail">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              Av. Alfredo Egídio de Souza Aranha, 384 – Chácara Santo Antônio, São Paulo – SP, 04730-090
            </div>
            <div class="loc-detail">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
              Fácil acesso pela Marginal Pinheiros · Próximo ao Aeroporto de Congonhas
            </div>
            <div class="loc-detail">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
              Ao lado da estação Granja Julieta · Estacionamento disponível
            </div>
          </div>
          <a
            href="https://maps.google.com/?q=Av.+Alfredo+Egídio+de+Souza+Aranha,+384,+São+Paulo"
            target="_blank"
            class="btn btn-primary"
          >
            Agende sua visita
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
          </a>
        </div>
        <div class="loc-map reveal">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3656.9!2d-46.7200!3d-23.6120!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x94ce51f8a6e0b8a5%3A0x0!2sAv.%20Alfredo%20Eg%C3%ADdio%20de%20Souza%20Aranha%2C%20384%20-%20Ch%C3%A1cara%20Santo%20Ant%C3%B4nio%2C%20S%C3%A3o%20Paulo%20-%20SP!5e0!3m2!1spt-BR!2sbr!4v1700000000000"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Localização Espaço Fit Eventos"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <div class="container">
      <div class="footer-main">
        <div class="footer-brand">
          <a href="/" class="logo-footer">
            <Img src="logo.fiteventos.webp" alt="Espaço Fit Eventos" />
          </a>
          <a
            href="https://www.instagram.com/espacofit.eventos/"
            class="footer-insta"
            aria-label="Instagram"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
          </a>
        </div>
        <div class="footer-contact-list">
          <div class="footer-contact-label">Contato</div>
          <div class="footer-contact-item">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.1a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.18h3a2 2 0 0 1 2 1.72c.127.96.36 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.34 1.85.573 2.81.7a2 2 0 0 1 1.72 2.02z"></path></svg>
            <a href="tel:+551132620938">(11) 3262-0938</a>
          </div>
          <div class="footer-contact-item">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"></path><path d="M12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0 0 20.455 3.48 11.815 11.815 0 0 0 12.05 0z"></path></svg>
            <a href="https://wa.me/551132620819" target="_blank">(11) 3262-0819</a>
          </div>
          <div class="footer-contact-item">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            <a href="mailto:contato@espacofiteventos.com.br">contato@espacofiteventos.com.br</a>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p class="footer-copy">
          Copyright © 2026 Espaço Fit Eventos — Todos os direitos reservados
        </p>
        <p class="footer-dev">
          Desenvolvido por <a href="http://dmove.com.br" target="_blank">
            <Img src="logo.dmove.avif" alt="DMove Marketing" class="footer-dmove-logo" />
          </a>
        </p>
      </div>
    </div>
  </footer>

  <!-- WHATSAPP FLOAT -->
  <a href="https://wa.me/551132620819" target="_blank" class="wa-float" aria-label="WhatsApp">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"></path>
    </svg>
  </a>
</Base>

<script>
  import "../scripts/institucional.js";

  // Section carousels (corporativos + sociais)
  document.querySelectorAll<HTMLElement>('.ev-carousel').forEach((carousel) => {
    const track = carousel.querySelector<HTMLElement>('.ev-carousel-track');
    if (!track) return;
    const origSlides = Array.from(track.querySelectorAll<HTMLElement>('.ev-carousel-slide'));
    const total = origSlides.length;
    if (total < 2) return;

    // Clone slides for infinite loop
    origSlides.forEach(s => track.appendChild(s.cloneNode(true)));
    const allSlides = Array.from(track.querySelectorAll<HTMLElement>('.ev-carousel-slide'));

    let current = 0, busy = false;

    function setWidths() {
      const w = carousel.offsetWidth;
      allSlides.forEach(s => { s.style.width = w + 'px'; });
      track.style.transition = 'none';
      track.style.transform = `translateX(-${current * carousel.offsetWidth}px)`;
    }

    setWidths();
    window.addEventListener('resize', setWidths);

    const getW = () => carousel.offsetWidth;

    function go(dir: number) {
      if (busy) return;
      busy = true;
      if (dir === -1 && current === 0) {
        track.style.transition = 'none';
        track.style.transform = `translateX(-${total * getW()}px)`;
        track.offsetHeight;
        current = total - 1;
        track.style.transition = 'transform 0.65s ease';
        track.style.transform = `translateX(-${current * getW()}px)`;
        setTimeout(() => { busy = false; }, 700);
      } else {
        current += dir;
        track.style.transition = 'transform 0.65s ease';
        track.style.transform = `translateX(-${current * getW()}px)`;
        setTimeout(() => {
          if (current >= total) {
            track.style.transition = 'none';
            current -= total;
            track.style.transform = `translateX(-${current * getW()}px)`;
          }
          busy = false;
        }, 700);
      }
    }

    let timer = setInterval(() => go(1), 4500);
    const resetTimer = () => { clearInterval(timer); timer = setInterval(() => go(1), 4500); };
    carousel.querySelector('.ev-carousel-prev')?.addEventListener('click', () => { go(-1); resetTimer(); });
    carousel.querySelector('.ev-carousel-next')?.addEventListener('click', () => { go(1); resetTimer(); });
  });
</script>

