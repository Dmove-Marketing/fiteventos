<script>
  import "../scripts/institucional.js";

  const outer = document.querySelector<HTMLElement>('.dep-carousel-outer');
  const inner = outer?.querySelector<HTMLElement>('.dep-carousel-inner');
  const track = outer?.querySelector<HTMLElement>('.dep-carousel-track');
  if (outer && inner && track) {
    const orig = Array.from(track.querySelectorAll<HTMLElement>('.dep-card'));
    const total = orig.length;

    orig.forEach(s => track.appendChild(s.cloneNode(true)));
    const all = Array.from(track.querySelectorAll<HTMLElement>('.dep-card'));

    let current = 0, busy = false;

    const visible = () => window.innerWidth <= 600 ? 1 : 3;
    const cardW = () => inner.offsetWidth / visible();

    function setWidths() {
      all.forEach(s => (s.style.width = cardW() + 'px'));
      track.style.transition = 'none';
      track.style.transform = `translateX(-${current * cardW()}px)`;
    }

    setWidths();
    window.addEventListener('resize', setWidths);

    function go(dir: number) {
      if (busy) return;
      busy = true;
      if (dir === -1 && current === 0) {
        track.style.transition = 'none';
        current = total;
        track.style.transform = `translateX(-${current * cardW()}px)`;
        track.offsetHeight;
        current -= 1;
        track.style.transition = 'transform 0.5s ease';
        track.style.transform = `translateX(-${current * cardW()}px)`;
      } else {
        current += dir;
        track.style.transition = 'transform 0.5s ease';
        track.style.transform = `translateX(-${current * cardW()}px)`;
      }
      setTimeout(() => {
        if (current >= total) {
          track.style.transition = 'none';
          current -= total;
          track.style.transform = `translateX(-${current * cardW()}px)`;
        }
        busy = false;
      }, 550);
    }

    outer.querySelector('.dep-prev')?.addEventListener('click', () => go(-1));
    outer.querySelector('.dep-next')?.addEventListener('click', () => go(1));
    let timer = setInterval(() => go(1), 4500);
    outer.addEventListener('mouseenter', () => clearInterval(timer));
    outer.addEventListener('mouseleave', () => { timer = setInterval(() => go(1), 4500); });
  }
</script>

