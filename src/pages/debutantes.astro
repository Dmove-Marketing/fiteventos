---
// Gerado a partir de: debutantes.html
import Base from '../layouts/Base.astro';
import config from '../../config.json';
import Img from '../components/ui/Img.astro';
import Video from '../components/ui/Video.astro';
import LeadForm from '../components/forms/LeadForm.astro';
import WhatsAppFormWidget from '../components/ui/WhatsAppFormWidget.astro';
import '../styles/debutantes.css';
import videoThumb from '../assets/images/2DECOR_1571_DSC08215_resultado.avif';
import ogImg from '../assets/images/compartilhamento.fiteventos.webp';
import heroSlide1 from '../assets/images/hero_carrossel.01.webp';
import heroSlide2 from '../assets/images/hero_carrossel.02.webp';
import heroSlide3 from '../assets/images/hero_carrossel.03.webp';
import heroSlide4 from '../assets/images/hero_carrossel.04.webp';
import heroSlide5 from '../assets/images/hero_carrossel.05.webp';
import heroSlide6 from '../assets/images/hero_carrossel.06.webp';
const heroSlides = [heroSlide1.src, heroSlide2.src, heroSlide3.src, heroSlide4.src, heroSlide5.src, heroSlide6.src];

import heroMobile1 from '../assets/images/heromobile-01_resultado.webp';
import heroMobile2 from '../assets/images/heromobile-02_resultado.webp';
import heroMobile3 from '../assets/images/heromobile-03_resultado.webp';
import heroMobile4 from '../assets/images/heromobile-04_resultado.webp';
import heroMobile5 from '../assets/images/heromobile-05_resultado.webp';
import heroMobile6 from '../assets/images/heromobile-06_resultado.webp';
const heroSlidesMobile = [heroMobile1.src, heroMobile2.src, heroMobile3.src, heroMobile4.src, heroMobile5.src, heroMobile6.src];
---

<Base
  title="Debutantes – Espaço Fit Eventos"
  description="Espaço Fit Eventos — Debutantes. 17 ambientes, 10 andares, capacidade para até 530 convidados."
  ogImage={ogImg.src}
>
<nav id="navbar">
        <a href="#" class="nav-logo">
            <Img src="logo.fiteventos.webp" alt="Espaço Fit Eventos" priority />
        </a>
        <ul class="nav-links">
            <li><a href="#ambientes">Ambientes</a></li>
            <li><a href="#estrutura">Estrutura</a></li>
            <li><a href="#gastronomia">Gastronomia</a></li>
            <li><a href="#galeria">Galeria</a></li>
            <li><a href="#contato">Contato</a></li>
        </ul>
        <a href="#contato" class="nav-cta">Solicitar orçamento</a>
        <button class="nav-hamburger" id="hamburgerBtn" aria-label="Abrir menu">
            <span></span><span></span><span></span>
        </button>
    </nav>

    <div class="mobile-menu" id="mobileMenu">
        <a href="#ambientes">Ambientes</a>
        <a href="#estrutura">Estrutura</a>
        <a href="#gastronomia">Gastronomia</a>
        <a href="#galeria">Galeria</a>
        <a href="#contato">Contato</a>
        <a href="#contato" class="mobile-cta">Solicitar orçamento</a>
    </div>

    <section class="hero">
        <div class="hero-bg hero-bg-front" id="heroBgFront" data-slides={JSON.stringify(heroSlides)} data-slides-mobile={JSON.stringify(heroSlidesMobile)}></div>
        <div class="hero-bg hero-bg-back" id="heroBgBack"></div>
        <div class="hero-overlay"></div>
        <div class="hero-content">
            <span class="hero-tag">São Paulo · Debutantes</span>
            <h1 class="hero-title">Cada detalhe pensado<br><em>para você brilhar</em></h1>
            <p class="hero-subtitle">Estrutura e serviços completos para transformar sua festa de 15 anos em uma experiência inesquecível.</p>
            <div class="hero-actions">
                <a href="#contato" class="btn-primary">Solicitar orçamento</a>
            </div>
        </div>
    </section>

    <div class="stats-bar">
        <div class="stat-item"><span class="stat-num">+500</span><span class="stat-label">convidados em pé</span></div>
        <div class="stat-item"><span class="stat-num">+10</span><span class="stat-label">anos de experiência</span></div>
    </div>

    <section class="sobre">
        <div class="sobre-media">
            <Video src="https://eventos.espacofiteventos.com.br/wp-content/uploads/2026/04/Untitled.mp4" poster={videoThumb.src} title="Vídeo" description="" uploadDate="2025-01-01" duration="PT1M" />
        </div>
        <div class="sobre-content" style="opacity:0;transform:translateY(24px);transition:opacity .8s,transform .8s">
            <span class="section-tag">Sobre o espaço</span>
            <h2 class="section-title">17 ambientes distribuídos em <br><em>10 andares de versatilidade</em></h2>
            <p class="section-body">Com 17 ambientes distribuídos em 10 andares, oferecemos flexibilidade para
                criar desde festas intimistas até grandes celebrações de debutantes. Cada
                espaço foi pensado para acompanhar cada momento da festa, da recepção à
                pista de dança.</p>
            <p class="section-body" style="margin-bottom:0">Com capacidade de <b>50 a 530 convidados</b>, os
                salões se adaptam a diferentes formatos, como recepção, jantar, cerimônia,
                valsa e pista de dança. O ambiente também conta com lounges para fotos e vídeos,
                além de áreas de recepção ideais para welcome drinks e experiências
                interativas.</p>
        </div>
    </section>

    <section class="ambientes" id="ambientes">
        <div class="ambientes-header">
            <span class="section-tag">Nossos ambientes</span>
            <h2 class="section-title">Ambientes modernos para uma <br><em>festa de debutante única</em></h2>
            <p class="ambientes-desc">Os espaços são pensados para acompanhar cada momento da festa, com
                integração entre os ambientes que garante uma experiência fluida para todos os
                convidados.</p>
        </div>
        <div class="ambientes-grid">
            <div class="ambientes-item"><Img src="2DECOR_1064_RICK6215-Copia_resultado.avif" alt="Ambiente decorado para debutante" /></div>
            <div class="ambientes-item"><Img src="2DECOR_1065_RICK6217-31-03-2026-13-26-01_resultado.avif" alt="Decoração de festa de 15 anos" /></div>
            <div class="ambientes-item"><Img src="2DECOR_1145_DSC07536_resultado.avif" alt="Espaço para cerimônia de debutante" /></div>
            <div class="ambientes-item"><Img src="WhatsApp Image 2026-05-05 at 18.10.55.jpeg" alt="Ambiente do Espaço Fit Eventos" /></div>
            <div class="ambientes-item"><Img src="camarim.fit.webp" alt="Camarim do Espaço Fit Eventos" /></div>
            <div class="ambientes-item"><Img src="WhatsApp Image 2026-05-05 at 18.10.57.jpeg" alt="Ambiente do Espaço Fit Eventos" /></div>
        </div>
    </section>

    <section class="estrutura" id="estrutura">
        <div class="estrutura-header" style="opacity:0;transform:translateY(24px);transition:opacity .8s,transform .8s">
            <span class="section-tag">Infraestrutura</span>
            <h2 class="section-title">Estrutura completa para transformar <br>sua festa de 15 anos<br><em>em um
                    verdadeiro
                    espetáculo</em></h2>
            <p class="section-body">Da iluminação à sonorização, tudo contribui para
                criar uma experiência envolvente, emocionante e inesquecível.</p>
        </div>
        <div class="estrutura-grid">
            <div class="estrutura-card"><Img src="2DECOR_1067_RICK6219-Copia_resultado-1024x685.avif" alt="Painéis de LED e projeção mapeada" />
                <div class="estrutura-card-label"><span>Painéis de LED e projeção mapeada</span></div>
            </div>
            <div class="estrutura-card"><Img src="5FES_2825_RICK7651_resultado-1024x684.avif" alt="Estrutura para DJ e pista de dança" />
                <div class="estrutura-card-label"><span>Estrutura para DJ e pista de dança</span></div>
            </div>
            <div class="estrutura-card"><Img src="2DECOR_1571_DSC08215_resultado-1024x684.avif" alt="Estrutura audiovisual completa" />
                <div class="estrutura-card-label"><span>Estrutura audiovisual completa</span></div>
            </div>
        </div>
    </section>

    <section class="gastronomia" id="gastronomia">
        <div class="gastro-img"></div>
        <div class="gastro-content" style="opacity:0;transform:translateY(24px);transition:opacity .8s,transform .8s">
            <span class="section-tag">Gastronomia</span>
            <h2 class="section-title">Uma experiência gastronômica <br><em>à altura da sua noite</em></h2>
            <p class="section-body">Da recepção ao grande momento da festa, a gastronomia, assinada pelo <b>Chef Dalton Rangel</b>, é pensada
                para surpreender. Oferecemos menus personalizados para festas de debutantes, incluindo coquetéis,
                ilhas gastronômicas, finger foods e jantar completo, sempre adaptados ao estilo da debutante e ao
                perfil dos convidados.</p>
            <p class="section-body" style="margin-bottom:0">Opções inclusivas, como menus vegetarianos e
                veganos, também fazem parte da experiência.</p>
            <div class="gastro-tags">
                <span class="gastro-tag">Coquetéis</span>
                <span class="gastro-tag">Ilhas gastronômicas</span>
                <span class="gastro-tag">Finger foods</span>
                <span class="gastro-tag">Jantar completo</span>
                <span class="gastro-tag">Menus vegetarianos</span>
                <span class="gastro-tag">Menus veganos</span>
            </div>
        </div>
    </section>

    <section class="diferenciais">
        <div class="diferenciais-header"
            style="opacity:0;transform:translateY(24px);transition:opacity .8s,transform .8s">
            <span class="section-tag">Diferenciais</span>
            <h2 class="section-title">Diferenciais que tornam sua festa <br><em>de 15 anos extraordinária</em></h2>
            <p class="section-body">Uma combinação de estrutura, personalização e
                atendimento que faz toda a diferença.</p>
        </div>
        <div class="diferenciais-grid">
            <div class="dif-card">
                <div class="dif-card-icon"><svg viewBox="0 0 24 24">
                        <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
                        <path d="M2 17l10 5 10-5"></path>
                        <path d="M2 12l10 5 10-5"></path>
                    </svg></div><span class="dif-card-title">Personalização do evento<br>conforme seu estilo</span>
            </div>
            <div class="dif-card">
                <div class="dif-card-icon"><svg viewBox="0 0 24 24">
                        <path d="M20 9V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v3"></path>
                        <path d="M2 11v5a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-5a2 2 0 0 0-4 0z"></path>
                        <path d="M4 18v2"></path>
                        <path d="M20 18v2"></path>
                    </svg></div><span class="dif-card-title">Camarim exclusivo para a debutante</span>
            </div>
            <div class="dif-card">
                <div class="dif-card-icon"><svg viewBox="0 0 24 24">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                        <circle cx="9" cy="7" r="4"></circle>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                    </svg></div><span class="dif-card-title">Espaço para até 530 convidados</span>
            </div>
            <div class="dif-card">
                <div class="dif-card-icon"><svg viewBox="0 0 24 24">
                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                    </svg></div><span class="dif-card-title">Atendimento altamente elogiado</span>
            </div>
            <div class="dif-card">
                <div class="dif-card-icon"><svg viewBox="0 0 24 24">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                        <circle cx="12" cy="10" r="3"></circle>
                    </svg></div><span class="dif-card-title">Localização privilegiada em São Paulo</span>
            </div>
            <div class="dif-card">
                <div class="dif-card-icon"><svg viewBox="0 0 24 24">
                        <line x1="12" y1="1" x2="12" y2="23"></line>
                        <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                    </svg></div><span class="dif-card-title">Excelente custo-benefício</span>
            </div>
        </div>
    </section>

    <section class="depoimentos" style="opacity:0;transform:translateY(24px);transition:opacity .8s,transform .8s">
        <div class="depoimentos-header">
            <span class="section-tag">Depoimentos</span>
            <h2 class="section-title">Momentos especiais contados por quem já <br><em>celebrou no Fit Eventos</em></h2>
        </div>
        <div class="dep-carousel">
            <button class="dep-btn dep-btn-prev" id="depPrev" aria-label="Anterior">&lsaquo;</button>
            <div class="dep-track" id="depTrack">
                <div class="dep-card">
                    <p class="dep-card-text">Realizamos nosso primeiro evento (Tax &amp; Pay Summit 2025) sem nenhuma
                        experiência. Só foi possível graças a todo suporte e atendimento dado
                        pelo Daniel e Time da Espaço Fit Eventos. A equipe de áudio visual foi atenciosa e
                        muito profissional. Serviço de cozinha impecável. Recomendamos de olhos fechados.</p>
                    <span class="dep-card-author">Marco Polo Viana</span>
                </div>
                <div class="dep-card">
                    <p class="dep-card-text">Tivemos a oportunidade de realizar um evento na sala 12 para 70 pessoas.
                        Fomos bem recebidos e atendidos pela Paula Lima e equipe. Do café ao áudio visual,
                        não tivemos nenhum tipo de problema, sempre proativos, pontuais e muito solícitos.
                        Super recomendamos o Espaço Fit Eventos.</p>
                    <span class="dep-card-author">Aline Amaral</span>
                </div>
                <div class="dep-card">
                    <p class="dep-card-text">Espaço muito bacana, comida gostosa, único ponto de
                        atenção é os elevadores que comportam apenas 6 pessoas o que pode gerar
                        filas. De modo geral comunicação com o time de organização sempre
                        foi claro e transparente. Adoramos tudo no evento.</p>
                    <span class="dep-card-author">Kelly Andraade</span>
                </div>
                <div class="dep-card">
                    <p class="dep-card-text">Lugar bastante agradável. Moderno, clean e aconchegante. Participei
                        do evento Inabalável da equipe Empoderamento Adolescente e foi maravilhoso. O local
                        possui estacionamento e fácil acesso pela Nações Unidas.</p>
                    <span class="dep-card-author">Mark</span>
                </div>
                <div class="dep-card">
                    <p class="dep-card-text">Organizamos um grande evento no espaço, para aproximadamente 400
                        pessoas. O espaço é muito bem localizado, amplo e com diversas
                        opções de salas e personalizações. Destaco principalmente o
                        atendimento da equipe comercial e também da prestatividade do time de
                        operações.</p>
                    <span class="dep-card-author">Alex Pereira</span>
                </div>
                <div class="dep-card">
                    <p class="dep-card-text">O local é bem moderno, com excelente tamanho para eventos de
                        apresentações e até mesmo teambuilding. O serviço é muito
                        bom, funcionários educados e bem prestativos. Gastronomia também excelente.</p>
                    <span class="dep-card-author">Natalia Gonçalves</span>
                </div>
                <div class="dep-card">
                    <p class="dep-card-text">Honesto e eficiente. Ótimo receptivo, atendimento, catering, tudo
                        muito limpo e ajeitado. Apesar de longe, tem vantagens, como pé direito alto e tudo o que
                        citei. Ótimo para eventos!</p>
                    <span class="dep-card-author">Carol Herling Grinbaum</span>
                </div>
                <div class="dep-card">
                    <p class="dep-card-text">Estive presente em um evento da minha empresa no espaço Fit e
                        saí de lá encantada com tudo. Quero deixar o meu elogio à colaboradora
                        Paula que me atendeu com excelência e simpatia. Tudo que era solicitado ela fazia e
                        resolvia de bom grado.</p>
                    <span class="dep-card-author">Maria Eduarda França</span>
                </div>
            </div>
            <button class="dep-btn dep-btn-next" id="depNext" aria-label="Próximo">&rsaquo;</button>
        </div>
    </section>

    <div class="galeria-header" id="galeria"
        style="opacity:0;transform:translateY(24px);transition:opacity .8s,transform .8s">
        <span class="section-tag">Galeria</span>
        <h2 class="section-title">Veja como sua festa de 15 anos<br><em>pode ganhar vida</em></h2>
    </div>

    <div class="galeria">
        <div class="galeria-item tall"><Img src="3RECEP_1620_RICK6734_resultado.avif" alt="Recepção de debutante" /></div>
        <div class="galeria-item"><Img src="2DECOR_1075_RICK6232_resultado.avif" alt="Decoração de festa" /></div>
        <div class="galeria-item"><Img src="2DECOR_1289_0W1A0209_resultado.avif" alt="Ambiente de recepção" /></div>
        <div class="galeria-item"><Img src="1MKOF_1129_RICK6291_resultado.avif" alt="Momento da festa" /></div>
        <div class="galeria-item"><Img src="2DECOR_1571_DSC08215_resultado.avif" alt="Detalhes da decoração" /></div>
    </div>

    <section class="contato-section" id="contato">
        <div class="contato-info" style="opacity:0;transform:translateY(24px);transition:opacity .8s,transform .8s">
            <span class="section-tag">Próximo passo</span>
            <h2 class="section-title">Vamos começar a planejar<br><em>sua festa dos sonhos?</em></h2>
            <p class="section-body">Preencha os dados para receber um orçamento com disponibilidade, valores e
                opções para o seu evento.</p>
        </div>
        <div class="contato-form-wrap"
            style="opacity:0;transform:translateY(24px);transition:opacity .8s,transform .8s">
            <LeadForm
              formId="lead-form"
              prefix="fit"
              project={config.project_slug}
              submitUrl={config.forms['lead-form'].webhooks[0]}
              redirectUrl={config.forms['lead-form'].redirect_on_success}
              submitText="Enviar solicitação"
              honeypot
              fields={[
                { name: 'nome',       type: 'text',     placeholder: 'Seu nome completo',                    required: true,  full: true },
                { name: 'email',      type: 'email',    placeholder: 'seu@email.com',                        required: true,  full: true },
                { name: 'telefone',   type: 'tel',      placeholder: '(11) 9 0000-0000',                     required: true  },
                { name: 'tipo',       type: 'select',   placeholder: '',                                     required: true,  options: [
                    { value: '',                  label: 'Tipo de evento',    disabled: true, selected: true },
                    { value: 'Eventos sociais',   label: 'Eventos sociais'   },
                    { value: 'Casamentos',        label: 'Casamentos'        },
                    { value: 'Mini Wedding',      label: 'Mini Wedding'      },
                    { value: 'Aniversários',      label: 'Aniversários'      },
                    { value: 'Debutantes',        label: 'Debutantes'        },
                    { value: 'Formatura',         label: 'Formatura'         },
                    { value: 'Bodas',             label: 'Bodas'             },
                    { value: 'Festas Judaicas',   label: 'Festas Judaicas'   },
                    { value: 'Bar Mitzvah',       label: 'Bar Mitzvah'       },
                    { value: 'Bat Mitzvah',       label: 'Bat Mitzvah'       },
                  ] },
                { name: 'data',       type: 'text',     placeholder: 'Data do evento',                       required: true, readonly: true  },
                { name: 'convidados', type: 'number',   placeholder: 'Nº de convidados',                     required: true  },
                { name: 'mensagem',   type: 'textarea', placeholder: 'Detalhes adicionais (não obrigatório)', required: false, full: true },
              ]}
            />
        </div>
    </section>

    <section class="mapa-section">
        <div class="mapa-wrapper">
            <Img src="mapa.png" alt="Localização do Espaço Fit Eventos" class="mapa-img" />
            <div class="mapa-overlay"></div>
        </div>
    </section>

    <footer>
        <div class="footer-bottom">
            <p class="footer-copy">&copy; 2026 Espaço Fit Eventos — Todos os direitos reservados.</p>
            <a href="#" class="footer-logo-bottom" aria-label="Espaço Fit Eventos">
                <Img src="logo.fiteventos.webp" alt="Espaço Fit Eventos" />
            </a>
            <div class="footer-dev">
                <span class="footer-dev-text">Desenvolvido por:</span>
                <a href="http://dmove.com.br" target="_blank" rel="noopener noreferrer">
                    <Img src="Versao-Principal-Negativo-scaled-e1750426923582.avif" alt="DMove" class="footer-dev-img" />
                </a>
            </div>
        </div>
    </footer>

    <WhatsAppFormWidget
      submitUrl={config.forms['lead-form'].webhooks[0]}
      project={config.project_slug}
    />

    
    
    
</Base>
<script>
  import '../scripts/debutantes.js';
</script>
