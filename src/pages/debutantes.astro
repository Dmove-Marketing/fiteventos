---
// Gerado a partir de: debutantes.html
import Base from '../layouts/Base.astro';
import config from '../../config.json';
import Img from '../components/ui/Img.astro';
import Video from '../components/ui/Video.astro';
import LeadForm from '../components/forms/LeadForm.astro';
import '../styles/debutantes.css';
---

<Base
  title="Debutantes – Espaço Fit Eventos"
  description="Realize a festa de 15 anos dos seus sonhos no Espaço Fit Eventos. Ambientes exclusivos, gastronomia assinada e toda a estrutura para uma noite inesquecível em São Paulo."
  ogImage="/images/novo_logo.png"
>
<nav id="navbar">
        <a href="#" class="nav-logo">
            <Img src="b6141e8a-26b2-4a98-a24a-572b061dd41b.png" alt="Espaço Fit Eventos" priority />
        </a>
        <ul class="nav-links">
            <li><a href="#ambientes">Ambientes</a></li>
            <li><a href="#estrutura">Estrutura</a></li>
            <li><a href="#gastronomia">Gastronomia</a></li>
            <li><a href="#galeria">Galeria</a></li>
            <li><a href="#contato">Contato</a></li>
        </ul>
        <a href="#contato" class="nav-cta">Solicitar orçamento</a>
        <button class="nav-hamburger" id="hamburgerBtn" aria-label="Abrir menu">
            <span></span><span></span><span></span>
        </button>
    </nav>

    <div class="mobile-menu" id="mobileMenu">
        <button class="mobile-close" id="mobileClose" aria-label="Fechar menu">✕</button>
        <a href="#ambientes">Ambientes</a>
        <a href="#estrutura">Estrutura</a>
        <a href="#gastronomia">Gastronomia</a>
        <a href="#galeria">Galeria</a>
        <a href="#contato">Contato</a>
        <a href="#contato" class="mobile-cta">Solicitar orçamento</a>
    </div>

    <section class="hero">
        <div id="hero-slides">
            <div class="hero-slide hero-d active"><Img src="hero_carrossel.01.webp" alt="" priority width={1920} /></div>
            <div class="hero-slide hero-d"><Img src="hero_carrossel.02.webp" alt="" width={1920} /></div>
            <div class="hero-slide hero-d"><Img src="hero_carrossel.03.webp" alt="" width={1920} /></div>
            <div class="hero-slide hero-d"><Img src="hero_carrossel.04.webp" alt="" width={1920} /></div>
            <div class="hero-slide hero-d"><Img src="hero_carrossel.05.webp" alt="" width={1920} /></div>
            <div class="hero-slide hero-d"><Img src="hero_carrossel.06.webp" alt="" width={1920} /></div>
            <div class="hero-slide hero-m active"><Img src="heromobile-01_resultado.webp" alt="" priority width={768} /></div>
            <div class="hero-slide hero-m"><Img src="heromobile-02_resultado.webp" alt="" width={768} /></div>
            <div class="hero-slide hero-m"><Img src="heromobile-03_resultado.webp" alt="" width={768} /></div>
            <div class="hero-slide hero-m"><Img src="heromobile-04_resultado.webp" alt="" width={768} /></div>
            <div class="hero-slide hero-m"><Img src="heromobile-05_resultado.webp" alt="" width={768} /></div>
            <div class="hero-slide hero-m"><Img src="heromobile-06_resultado.webp" alt="" width={768} /></div>
        </div>
        <div class="hero-overlay"></div>
        <div class="hero-content">
            <span class="hero-tag">São Paulo · Debutantes</span>
            <h1 class="hero-title">Sua festa de 15 anos com estilo, emoção <br><em>e personalidade</em></h1>
            <p class="hero-subtitle">O Espaço Fit Eventos é mais do que um espaço para eventos: é um conceito. Com arquitetura arrojada e funcional, criamos o ambiente perfeito para você comemorar do seu jeito.</p>
            <div class="hero-actions">
                <a href="#contato" class="btn-primary">Solicitar orçamento</a>
                <a href="#ambientes" class="btn-ghost">Conhecer os ambientes</a>
            </div>
        </div>
    </section>


    <section class="sobre">
        <div class="sobre-media">
            <Video src="https://lp.espacofiteventos.com.br/video.debutantes.mp4" poster="" title="Vídeo" description="" uploadDate="2026-05-18" duration="PT1M" />
        </div>
        <div class="sobre-content" style="opacity:0;transform:translateY(24px);transition:opacity .8s,transform .8s">
            <span class="section-tag">Sobre o espaço</span>
            <h2 class="section-title">Detalhes pensado para <em>você brilhar</em></h2>
            <p class="section-body">Com capacidade para receber de <b>50 a 530 convidados</b>, os ambientes do Espaço Fit Eventos foram planejados para oferecer versatilidade, conforto e experiências memoráveis em cada etapa da celebração.
            Da recepção à pista de dança, os espaços se adaptam com facilidade a diferentes formatos e estilos de evento, contando com foyers integrados e lounges aconchegantes, ideais para welcome drinks, fotos e experiências interativas.
O grande diferencial está na versatilidade dos ambientes e no pé-direito alto, que permite à debutante ousar na cenografia e transformar o espaço no cenário que sempre imaginou, explorando diferentes recursos de iluminação, tecnologia e ambientação.</p>
        </div>
    </section>

    <section class="ambientes" id="ambientes">
        <div class="ambientes-header">
            <span class="section-tag">Nossos ambientes</span>
            <h2 class="section-title">Ambientes modernos <br class="br-m">para uma <span class="show-m">festa de </span><br class="hide-m"><em><span class="hide-m">festa de </span>debutante única</em></h2>
            <p class="ambientes-desc">Nossos espaços são um convite para você contar a sua história, que é única. Oferecemos liberdade de adaptação e integração entre os ambientes, transformando o Espaço Fit Eventos no palco perfeito para viver cada momento da sua celebração.</p>
        </div>
        <div class="ambientes-grid">
            <div class="ambientes-item"><Img src="2DECOR_1064_RICK6215-Copia_resultado.avif" alt="Ambiente decorado para debutante" /></div>
            <div class="ambientes-item"><Img src="2DECOR_1065_RICK6217-31-03-2026-13-26-01_resultado.avif" alt="Decoração de festa de 15 anos" /></div>
            <div class="ambientes-item"><Img src="2DECOR_1145_DSC07536_resultado.avif" alt="Espaço para cerimônia de debutante" /></div>
            <div class="ambientes-item"><Img src="2DECOR_1289_0W1A0209_resultado.avif" alt="Sala de eventos decorada" /></div>
            <div class="ambientes-item"><Img src="2DECOR_1269_DSC07655_resultado.avif" alt="Ambiente de recepção" /></div>
            <div class="ambientes-item"><Img src="camarim.fit.webp" alt="Camarim" /></div>
        </div>
    </section>

    <section class="estrutura" id="estrutura">
        <div class="estrutura-header" style="opacity:0;transform:translateY(24px);transition:opacity .8s,transform .8s">
            <span class="section-tag">Infraestrutura</span>
            <h2 class="section-title">Estrutura completa para transformar <br>sua festa de 15 anos<br><em>em um
                    verdadeiro espetáculo</em></h2>
            <p class="section-body">Da iluminação à sonorização, tudo contribui para
                criar uma experiência envolvente, emocionante e inesquecível.</p>
        </div>
        <div class="estrutura-grid">
            <div class="estrutura-card"><Img src="2DECOR_1067_RICK6219-Copia_resultado-1024x685.avif" alt="Painéis de LED e projeção mapeada" />
                <div class="estrutura-card-label"><span>Painéis de LED e projeção mapeada</span></div>
            </div>
            <div class="estrutura-card"><Img src="5FES_2825_RICK7651_resultado-1024x684.avif" alt="Estrutura para DJ e pista de dança" />
                <div class="estrutura-card-label"><span>Estrutura para DJ e pista de dança</span></div>
            </div>
            <div class="estrutura-card"><Img src="2DECOR_1571_DSC08215_resultado-1024x684.avif" alt="Estrutura audiovisual completa" />
                <div class="estrutura-card-label"><span>Estrutura audiovisual completa</span></div>
            </div>
        </div>
    </section>

    <section class="gastronomia" id="gastronomia">
        <div class="gastro-img">
            <div class="gastro-slides">
                <div class="gastro-slide active"><Img src="gastronomia.debutantes01.jpg" alt="Gastronomia Espaço Fit" priority /></div>
                <div class="gastro-slide"><Img src="gastronomia.debutantes02.jpg" alt="Gastronomia Espaço Fit" /></div>
                <div class="gastro-slide"><Img src="gastronomia.debutantes03.jpg" alt="Gastronomia Espaço Fit" /></div>
                <div class="gastro-slide"><Img src="gastronomia.debutantes04.jpg" alt="Gastronomia Espaço Fit" /></div>
                <div class="gastro-slide"><Img src="gastronomia.debutantes05.jpg" alt="Gastronomia Espaço Fit" /></div>
                <div class="gastro-slide"><Img src="gastronomia.debutantes06.jpg" alt="Gastronomia Espaço Fit" /></div>
            </div>
        </div>
        <div class="gastro-content" style="opacity:0;transform:translateY(24px);transition:opacity .8s,transform .8s">
            <span class="section-tag">Gastronomia</span>
            <h2 class="section-title">Uma experiência gastronômica <br><em>à altura da sua noite</em></h2>
            <p class="section-body">Com a assinatura do premiado <b>Chef Dalton Rangel</b>, a gastronomia do Espaço Fit Eventos combina tradição e contemporaneidade em experiências cuidadosamente elaboradas para tornar cada celebração ainda mais memorável.
Os menus autorais valorizam ingredientes selecionados, apresentações sofisticadas e opções personalizadas, incluindo versões vegetarianas e veganas pensadas especialmente para a sua grande noite.
            <p class="section-body" style="margin-bottom:0">Para surpreender os convidados, oferecemos também experiências gastronômicas teens e interativas, com coquetéis sem álcool personalizados, milkshakes, pipocas gourmet, finger foods, massas e ilhas gastronômicas repletas de sabores e possibilidades.</p>
            <div class="gastro-tags">
                <span class="gastro-tag">Coquetéis</span>
                <span class="gastro-tag">Ilhas gastronômicas</span>
                <span class="gastro-tag">Finger foods</span>
                <span class="gastro-tag">Jantar completo</span>
                <span class="gastro-tag">Menus vegetarianos</span>
                <span class="gastro-tag">Menus veganos</span>
            </div>
        </div>
    </section>

    <section class="diferenciais">
        <div class="diferenciais-header"
            style="opacity:0;transform:translateY(24px);transition:opacity .8s,transform .8s">
            <span class="section-tag">Diferenciais</span>
            <h2 class="section-title">Diferenciais que <br class="br-m">tornam sua festa <br><em>de 15 anos extraordinária</em></h2>
            <p class="section-body">Uma combinação de estrutura, personalização e
                atendimento que faz toda a diferença.</p>
        </div>
        <div class="diferenciais-grid">
            <div class="dif-card">
                <div class="dif-card-icon"><svg viewBox="0 0 24 24">
                        <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
                        <path d="M2 17l10 5 10-5"></path>
                        <path d="M2 12l10 5 10-5"></path>
                    </svg></div><span class="dif-card-title">Personalização do evento conforme seu estilo</span>
            </div>
            <div class="dif-card">
                <div class="dif-card-icon"><svg viewBox="0 0 24 24">
                        <path d="M20 9V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v3"></path>
                        <path d="M2 11v5a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-5a2 2 0 0 0-4 0z"></path>
                        <path d="M4 18v2"></path>
                        <path d="M20 18v2"></path>
                    </svg></div><span class="dif-card-title">Camarim exclusivo para a debutante</span>
            </div>
            <div class="dif-card">
                <div class="dif-card-icon"><svg viewBox="0 0 24 24">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                        <circle cx="9" cy="7" r="4"></circle>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                    </svg></div><span class="dif-card-title">Espaço para até 530 convidados</span>
            </div>
            <div class="dif-card">
                <div class="dif-card-icon"><svg viewBox="0 0 24 24">
                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                    </svg></div><span class="dif-card-title">Atendimento altamente elogiado</span>
            </div>
            <div class="dif-card">
                <div class="dif-card-icon"><svg viewBox="0 0 24 24">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                        <circle cx="12" cy="10" r="3"></circle>
                    </svg></div><span class="dif-card-title">Localização privilegiada em São Paulo</span>
            </div>
            <div class="dif-card">
                <div class="dif-card-icon"><svg viewBox="0 0 24 24">
                        <line x1="12" y1="1" x2="12" y2="23"></line>
                        <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                    </svg></div><span class="dif-card-title">Excelente custo-benefício</span>
            </div>
        </div>
    </section>

    <section class="depoimentos" style="opacity:0;transform:translateY(24px);transition:opacity .8s,transform .8s">
        <div class="depoimentos-header">
            <span class="section-tag">Depoimentos</span>
            <h2 class="section-title">Momentos especiais contados por quem já <br><em>celebrou no Fit Eventos</em></h2>
        </div>
        <div class="dep-carousel">
            <button class="dep-btn dep-btn-prev" id="depPrev" aria-label="Anterior">&lsaquo;</button>
            <div class="dep-track" id="depTrack">
                <div class="dep-card">
                    <p class="dep-card-text">Lugar muito bonito e organizado. Funcionários atenciosos. E as comidas e bebidas são top!</p>
                    <span class="dep-card-author">Wladimir Monteiro</span>
                </div>
                <div class="dep-card">
                    <p class="dep-card-text">Muito bom, confortável, oferece os recursos necessários e, muito bem localizado, com fácil acesso. Tanto para quem está em SP, quanto pra quem vem dos interiores.</p>
                    <span class="dep-card-author">Valdemar Fernandes</span>
                </div>
                <div class="dep-card">
                    <p class="dep-card-text">Perfeito espaço. Salas mega equipadas, equipe muito gentil e preparada, destaque para o Vicente, Daniel, Paula, Jamile e Vitória. Que comida maravilhosa! Tudo muito bom. Indico demais.</p>
                    <span class="dep-card-author">Aila Santana</span>
                </div>
                <div class="dep-card">
                    <p class="dep-card-text">O evento no Espaço Fit Eventos foi sensacional, os profissionais são excelentes e a comida que forneceram foi muito bom também.</p>
                    <span class="dep-card-author">Gislaine Geisger</span>
                </div>
                <div class="dep-card">
                    <p class="dep-card-text">Fiquei impressionada com a organização e excelência de cada pessoa que me atendeu! Existe um padrão na excelência e no atendimento!</p>
                    <span class="dep-card-author">Renata Palmutti</span>
                </div>
                <div class="dep-card">
                    <p class="dep-card-text">Maravilhosos! Antes, durante e depois do evento. Parabéns equipe!</p>
                    <span class="dep-card-author">Milena Guimarães</span>
                </div>
                <div class="dep-card">
                    <p class="dep-card-text">Lugar muito aconchegante, excelente para eventos. Top!</p>
                    <span class="dep-card-author">Karina Melo</span>
                </div>
                <div class="dep-card">
                    <p class="dep-card-text">O Espaço Fit tem uma ótima estrutura para realização de eventos, tamanhos/formatos diversos de salas, equipe prestativa e profissional, recomendo! Aprovado!</p>
                    <span class="dep-card-author">Pedro Costa</span>
                </div>
            </div>
            <button class="dep-btn dep-btn-next" id="depNext" aria-label="Próximo">&rsaquo;</button>
        </div>
    </section>

    <div class="galeria-header" id="galeria"
        style="opacity:0;transform:translateY(24px);transition:opacity .8s,transform .8s">
        <span class="section-tag">Galeria</span>
        <h2 class="section-title">Veja como sua festa<br class="br-xs"> de 15 anos<br><em>pode ganhar vida</em></h2>
    </div>

    <div class="galeria">
        <div class="galeria-item tall"><Img src="3RECEP_1620_RICK6734_resultado.avif" alt="Recepção de debutante" /></div>
        <div class="galeria-item"><Img src="2DECOR_1075_RICK6232_resultado.avif" alt="Decoração de festa" /></div>
        <div class="galeria-item"><Img src="2DECOR_1289_0W1A0209_resultado.avif" alt="Ambiente de recepção" /></div>
        <div class="galeria-item"><Img src="1MKOF_1129_RICK6291_resultado.avif" alt="Momento da festa" /></div>
        <div class="galeria-item"><Img src="2DECOR_1571_DSC08215_resultado.avif" alt="Detalhes da decoração" /></div>
    </div>

    <section class="contato-section" id="contato">
        <div class="contato-info" style="opacity:0;transform:translateY(24px);transition:opacity .8s,transform .8s">
            <span class="section-tag">Próximo passo</span>
            <h2 class="section-title">Vamos começar a planejar<br><em>sua festa dos sonhos?</em></h2>
            <p class="section-body">Preencha os dados para receber um orçamento com disponibilidade, valores e
                opções para o seu evento.</p>
        </div>
        <div class="contato-form-wrap"
            style="opacity:0;transform:translateY(24px);transition:opacity .8s,transform .8s">
            <LeadForm
              formId="lead-form"
              project={config.project_slug}
              submitUrl={config.forms['lead-form'].webhooks[0]}
              redirectUrl={config.forms['lead-form'].redirect_on_success}
              submitText="Enviar solicitação"
              footerText="Seus dados são usados apenas para retorno de contato e orçamento."
              honeypot
              fields={[
                { name: 'nome', type: 'text', label: 'Nome', placeholder: 'Seu nome completo', required: true },
                { name: 'email', type: 'email', label: 'E-mail', placeholder: 'seu@email.com', required: true },
                { type: 'row', fields: [
                  { name: 'telefone', type: 'tel', label: 'WhatsApp', placeholder: '(11) 9 0000-0000', required: true },
                  { name: 'tipo_evento', type: 'select', label: 'Tipo de Evento', required: true, options: [
                    { value: '', label: 'Selecione...', disabled: true, selected: true },
                    { value: 'Eventos sociais', label: 'Eventos sociais' },
                    { value: 'Casamentos', label: 'Casamentos' },
                    { value: 'Mini Wedding', label: 'Mini Wedding' },
                    { value: 'Aniversários', label: 'Aniversários' },
                    { value: 'Debutantes', label: 'Debutantes' },
                    { value: 'Formatura', label: 'Formatura' },
                    { value: 'Bodas', label: 'Bodas' },
                    { value: 'Festas Judaicas', label: 'Festas Judaicas' },
                    { value: 'Bar Mitzvah', label: 'Bar Mitzvah' },
                    { value: 'Bat Mitzvah', label: 'Bat Mitzvah' },
                    { value: 'Outros', label: 'Outros' }
                  ]}
                ]},
                { type: 'row', fields: [
                  { name: 'data', type: 'text', label: 'Data do Evento', placeholder: 'Data do evento', required: true },
                  { name: 'convidados', type: 'number', label: 'Nº de Convidados', placeholder: 'Nº de pessoas', required: true }
                ]},
                { name: 'mensagem', type: 'textarea', label: 'Mensagem', placeholder: 'Detalhes adicionais (não obrigatório)', required: false },
              ] as any}
            />
        </div>
    </section>

    <section class="mapa-section">
        <div class="mapa-wrapper">
            <Img src="mapa.png" alt="Mapa Espaço Fit Eventos" />
        </div>
    </section>

    <footer>
        <div class="footer-bottom">
            <p class="footer-copy">&copy; 2026 Espaço Fit Eventos — Todos os direitos reservados.</p>
            <a href="#" class="footer-logo-bottom" aria-label="Espaço Fit Eventos">
                <Img src="b6141e8a-26b2-4a98-a24a-572b061dd41b.png" alt="Espaço Fit Eventos" />
            </a>
            <div class="footer-dev">
                <span class="footer-dev-text">Desenvolvido por:</span>
                <a href="http://dmove.com.br" target="_blank" rel="noopener noreferrer">
                    <Img src="Versao-Principal-Negativo-scaled-e1750426923582.avif" alt="DMove" class="footer-dev-img" />
                </a>
            </div>
        </div>
    </footer>

    <a href="https://wa.me/551132620819" target="_blank" rel="noopener noreferrer" class="whatsapp-float"
        aria-label="Fale conosco pelo WhatsApp">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
    </a>

    
    
    
</Base>
<script>
  import '../scripts/debutantes.js';
</script>
