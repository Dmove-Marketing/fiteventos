---
// Componente gerado a partir de: eventos-corporativos.html
import '../styles/eventos-corporativos.css';
import LeadForm from '../components/forms/LeadForm.astro';
---

<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Casa Voss — Espaço de Eventos Corporativos</title>
    <meta name="description"
        content="Casa Voss — Espaço de eventos corporativos em São Paulo. Auditório, salas, gourmet e lounge para até 250 pessoas. Sofisticação e acolhimento para a sua marca." />
    <meta property="og:title" content="Casa Voss — Espaço de Eventos Corporativos" />
    <meta property="og:description"
        content="Sofisticação e acolhimento para transformar seu evento em uma experiência inesquecível." />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pt_BR" />
    <link rel="icon"
        href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🌿</text></svg>" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://use.typekit.net/ruo8uhd.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@200;300;400;500;700&display=swap"
        rel="stylesheet" />
    <link rel="stylesheet" href="https://npmcdn.com/flatpickr/dist/flatpickr.min.css" />

    
    

    
</head>

<body>
    <noscript></noscript>

    <nav id="navbar">
        <a href="#" class="nav-logo">Casa Voss</a>
        <ul class="nav-links">
            <li><a href="#espacos">Espaços</a></li>
            <li><a href="#experiencia">Experiências</a></li>
            <li><a href="#galeria">Galeria</a></li>
            <li><a href="#contato">Contato</a></li>
        </ul>
        <a href="#contato" class="nav-cta" style="display:none!important;">Reservar</a>
        <button class="nav-hamburger" id="hamburgerBtn"
            aria-label="Abrir menu"><span></span><span></span><span></span></button>
    </nav>

    <div class="mobile-menu" id="mobileMenu">
        <a href="#espacos" class="mobile-link">Espaços</a>
        <a href="#experiencia" class="mobile-link">Experiências</a>
        <a href="#galeria" class="mobile-link">Galeria</a>
        <a href="#contato" class="mobile-link">Contato</a>
        <a href="#contato" class="mobile-cta">Reservar</a>
    </div>

    <section class="hero">
        <div class="hero-bg"></div>
        <div class="hero-overlay"></div>
        <div class="hero-content">
            <span class="hero-tag">São Paulo · Espaço Corporativo</span>
            <h1 class="hero-title">Onde marcas <br> encontram voz,<br><em>times se conectam</em><br> e ideias ganham
                forma.</h1>
            <p class="hero-subtitle">Uma casa de experiências corporativas para empresas que buscam mais do que um
                espaço: buscam presença, estética e significado.</p>
            <div class="hero-actions"><a href="#espacos" class="btn-primary">Conhecer espaços</a></div>
        </div>
    </section>

    <div class="stats-bar">
        <div class="stat-item"><span class="stat-num">600m²</span><span class="stat-label">de área total</span></div>
        <div class="stat-item"><span class="stat-num">5</span><span class="stat-label">ambientes únicos</span></div>
        <div class="stat-item"><span class="stat-num">250</span><span class="stat-label">pessoas por evento</span></div>
        <div class="stat-item"><span class="stat-num">100%</span><span class="stat-label">personalizado</span></div>
    </div>

    <section class="sobre">
        <div class="sobre-img"></div>
        <div class="sobre-content">
            <span class="section-tag">Sobre o espaço</span>
            <h2 class="section-title">Nem todo evento precisa <br>de um espaço. <br><em>Alguns precisam de uma
                    casa.</em></h2>
            <p class="section-body">Localizada no <b>Brooklin</b>, um dos <b>principais eixos corporativos de São
                    Paulo</b>, a casa combina acesso facilitado com uma atmosfera que foge do padrão impessoal dos
                centros de convenções. Distribuída em diferentes ambientes integrados, entre <b>auditórios, áreas de
                    convivência, rooftop e espaços gastronômicos</b>, a Casa VOSS foi desenhada para acomodar desde
                encontros mais intimistas até eventos completos de até 100 pessoas, com fluidez entre conteúdo,
                experiência e relacionamento. Uma casa criada para marcas que têm alma.</p>
        </div>
    </section>

    <section class="espacos" id="espacos">
        <div class="espacos-header">
            <span class="section-tag">Nossos espaços</span>
            <h2 class="section-title">Ambientes integrados, versáteis e <br><em>pensados para diferentes dinâmicas</em>
            </h2>
            <p class="espacos-desc">Para eventos que precisam gerar mais do que presença. <br>Precisam gerar
                significado.</p>
        </div>
        <div class="espacos-grid">
            <div class="espaco-card">
                <div class="espaco-card-img"><img
                        src="https://casavoss.com.br/wp-content/uploads/2026/04/Copia-de-064VIZ_IMG_02-Auditorio.avif"
                        alt="Espaço Âmbar Casa Voss" loading="lazy" /></div>
                <div class="espaco-card-body"><span class="espaco-name">Espaço Âmbar</span><span class="espaco-cap">Um
                        auditório contemporâneo e equipado, <b>ideal para apresentações, treinamentos e lançamentos</b>,
                        com <b>capacidade para até 96 convidados</b> em formato plenária ou mesas redondas, combinando
                        tecnologia, conforto e estética.</span><button class="espaco-card-btn"
                        onclick="document.getElementById('contato').scrollIntoView({behavior:'smooth'})">Solicitar
                        orçamento</button></div>
            </div>
            <div class="espaco-card">
                <div class="espaco-card-img"><img
                        src="https://casavoss.com.br/wp-content/uploads/2026/04/ChatGPT-Image-7-de-abr.-de-2026-22_10_20_resultado.avif"
                        alt="Espaço Sálvia Casa Voss" loading="lazy" /></div>
                <div class="espaco-card-body"><span class="espaco-name">Espaço Sálvia</span><span
                        class="espaco-cap">Para encontros que pedem mais conexão, um ambiente intimista <b>ideal para
                            workshops, mentorias e reuniões estratégicas</b>, com capacidade para até <b>36
                            convidados</b>.</span><button class="espaco-card-btn"
                        onclick="document.getElementById('contato').scrollIntoView({behavior:'smooth'})">Solicitar
                        orçamento</button></div>
            </div>
            <div class="espaco-card">
                <div class="espaco-card-img"><img
                        src="https://casavoss.com.br/wp-content/uploads/2026/04/Copia-de-064VIZ_IMG_08-Gourmet_resultado.avif"
                        alt="Espaço Gourmet Casa Voss" loading="lazy" /></div>
                <div class="espaco-card-body"><span class="espaco-name">Espaço Gourmet</span><span class="espaco-cap">Um
                        espaço onde o networking se mistura à gastronomia, <b>ideal para coffee breaks, almoços e
                            ativações com chefs convidados.</b></span><button class="espaco-card-btn"
                        onclick="document.getElementById('contato').scrollIntoView({behavior:'smooth'})">Solicitar
                        orçamento</button></div>
            </div>
            <div class="espaco-card">
                <div class="espaco-card-img"><img
                        src="https://casavoss.com.br/wp-content/uploads/2026/04/Copia-de-064VIZ_IMG_09-Garden-Lounge_resultado.avif"
                        alt="Garden Lounge Casa Voss" loading="lazy" /></div>
                <div class="espaco-card-body"><span class="espaco-name">Garden Lounge</span><span class="espaco-cap">Um
                        espaço ao ar livre que combina natureza e acolhimento, ideal para <b>workshops, treinamentos e
                            reuniões estratégicas mais intimistas.</b></span><button class="espaco-card-btn"
                        onclick="document.getElementById('contato').scrollIntoView({behavior:'smooth'})">Solicitar
                        orçamento</button></div>
            </div>
            <div class="espaco-card">
                <div class="espaco-card-img"><img
                        src="https://casavoss.com.br/wp-content/uploads/2026/04/WhatsApp-Image-2026-04-07-at-22.12_resultado.avif"
                        alt="Rooftop Casa Voss" loading="lazy" /></div>
                <div class="espaco-card-body"><span class="espaco-name">Rooftop</span><span class="espaco-cap">Com 210m²
                        de terraço e 42m² de área coberta, um espaço amplo, versátil e cercado de verde, ideal para
                        almoços, coquetéis e celebrações ao ar livre.</span><button class="espaco-card-btn"
                        onclick="document.getElementById('contato').scrollIntoView({behavior:'smooth'})">Solicitar
                        orçamento</button></div>
            </div>
        </div>
    </section>

    <section class="experiencia-voss" id="experiencia">
        <div class="experiencia-voss-header">
            <span class="section-tag">A experiência Voss</span>
            <h2 class="section-title">Perfeito para eventos corporativos que precisam <br><em>ir além do
                    tradicional</em></h2>
            <p class="section-body">Do conteúdo à celebração, cada formato encontra aqui a estrutura e a atmosfera
                ideais para acontecer com sucesso.</p>
        </div>
        <div class="exp-tipos-grid">
            <div class="exp-tipo-card">
                <div class="exp-tipo-icon"><svg viewBox="0 0 24 24">
                        <rect x="3" y="3" width="7" height="7" rx="1" />
                        <rect x="14" y="3" width="7" height="7" rx="1" />
                        <rect x="3" y="14" width="7" height="7" rx="1" />
                        <rect x="14" y="14" width="7" height="7" rx="1" />
                    </svg></div><span class="exp-tipo-title">Eventos corporativos e convenções</span>
                <p class="exp-tipo-desc">Estrutura completa para congressos, palestras e encontros de grande porte com
                    todo o suporte técnico e operacional.</p>
            </div>
            <div class="exp-tipo-card">
                <div class="exp-tipo-icon"><svg viewBox="0 0 24 24">
                        <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
                        <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
                    </svg></div><span class="exp-tipo-title">Treinamentos e workshops</span>
                <p class="exp-tipo-desc">Ambientes flexíveis que se adaptam a diferentes dinâmicas de aprendizado, do
                    formato expositivo ao colaborativo.</p>
            </div>
            <div class="exp-tipo-card">
                <div class="exp-tipo-icon"><svg viewBox="0 0 24 24">
                        <path d="M12 2L2 7l10 5 10-5-10-5z" />
                        <path d="M2 17l10 5 10-5" />
                        <path d="M2 12l10 5 10-5" />
                    </svg></div><span class="exp-tipo-title">Lançamentos de produto</span>
                <p class="exp-tipo-desc">Cenários planejados para gerar impacto, com cenografia, iluminação e tecnologia
                    integradas à identidade da marca.</p>
            </div>
            <div class="exp-tipo-card">
                <div class="exp-tipo-icon"><svg viewBox="0 0 24 24">
                        <polygon points="23 7 16 12 23 17 23 7" />
                        <rect x="1" y="5" width="15" height="14" rx="2" />
                    </svg></div><span class="exp-tipo-title">Gravações e conteúdos</span>
                <p class="exp-tipo-desc">Espaços com acústica controlada, infraestrutura AV profissional e cenários
                    naturais para produções audiovisuais.</p>
            </div>
            <div class="exp-tipo-card">
                <div class="exp-tipo-icon"><svg viewBox="0 0 24 24">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                        <circle cx="9" cy="7" r="4" />
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                        <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                    </svg></div><span class="exp-tipo-title">Team building gastronômico</span>
                <p class="exp-tipo-desc">Experiências que unem cooperação e gastronomia, com estrutura completa para
                    dinâmicas culinárias em grupo.</p>
            </div>
            <div class="exp-tipo-card">
                <div class="exp-tipo-icon"><svg viewBox="0 0 24 24">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z" />
                        <path d="M8 14s1.5 2 4 2 4-2 4-2" />
                        <line x1="9" y1="9" x2="9.01" y2="9" />
                        <line x1="15" y1="9" x2="15.01" y2="9" />
                    </svg></div><span class="exp-tipo-title">Aulas e experiências culinárias</span>
                <p class="exp-tipo-desc">Cozinha gourmet equipada para aulas práticas, demonstrações ao vivo e
                    experiências imersivas com chefs.</p>
            </div>
        </div>
    </section>

    <section class="gastronomia">
        <div class="gastro-img"></div>
        <div class="gastro-content">
            <span class="section-tag">Gastronomia</span>
            <h2 class="section-title">Quando a gastronomia <br>deixa de ser apoio e <br><em>se torna experiência</em>
            </h2>
            <p class="section-body">Assinada pelo chef Eliézer Formaggio, que traz a essência italiana da sua família
                para cada criação, e complementada por chefs parceiros, a cozinha une técnica, afeto e criatividade para
                criar experiências que marcam.</p>
            <p class="section-body">Aqui, o menu não é padrão, ele é construído de acordo com o momento, o público e o
                objetivo do evento, com propostas personalizadas para cada ocasião.</p>
            <div class="gastro-assinatura">
                <div class="gastro-assinatura-linha"></div><span class="gastro-assinatura-text">Chef Eliézer
                    Formaggio</span>
                <div class="gastro-assinatura-linha"></div>
            </div>
        </div>
    </section>

    <section class="diferenciais">
        <div class="diferenciais-header">
            <span class="section-tag">Diferenciais</span>
            <h2 class="section-title">Precisão nos detalhes. <br><em>Impacto no todo</em></h2>
            <p class="section-body">Uma curadoria que transforma cada escolha em parte de uma experiência maior.</p>
        </div>
        <div class="diferenciais-grid">
            <div class="dif-card">
                <div class="dif-card-icon"><svg viewBox="0 0 24 24">
                        <path d="M20 9V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v3" />
                        <path d="M2 11v5a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-5a2 2 0 0 0-4 0z" />
                        <path d="M4 18v2" />
                        <path d="M20 18v2" />
                    </svg></div><span class="dif-card-title">Mobiliário</span>
            </div>
            <div class="dif-card">
                <div class="dif-card-icon"><svg viewBox="0 0 24 24">
                        <path d="M8 2h8l4 10H4L8 2z" />
                        <path d="M12 12v6" />
                        <path d="M8 22v-2a4 4 0 0 1 8 0v2" />
                        <line x1="7" y1="12" x2="7" y2="18" />
                        <line x1="17" y1="12" x2="17" y2="18" />
                    </svg></div><span class="dif-card-title">Bar de drinks</span>
            </div>
            <div class="dif-card">
                <div class="dif-card-icon"><svg viewBox="0 0 24 24">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                        <path d="M12 8v4" />
                        <path d="M10 10h4" />
                    </svg></div><span class="dif-card-title">Decoração floral</span>
            </div>
            <div class="dif-card">
                <div class="dif-card-icon"><svg viewBox="0 0 24 24">
                        <path d="M9 18V5l12-2v13" />
                        <circle cx="6" cy="18" r="3" />
                        <circle cx="18" cy="16" r="3" />
                    </svg></div><span class="dif-card-title">Som e luz</span>
            </div>
        </div>
        <div class="dif-last-row">
            <div class="dif-card">
                <div class="dif-card-icon"><svg viewBox="0 0 24 24">
                        <polygon points="23 7 16 12 23 17 23 7" />
                        <rect x="1" y="5" width="15" height="14" rx="2" />
                        <path d="M8 2v3" />
                        <path d="M16 2v3" />
                    </svg></div><span class="dif-card-title">Cozinha gourmet para gravações</span>
            </div>
            <div class="dif-card">
                <div class="dif-card-icon"><svg viewBox="0 0 24 24">
                        <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6" />
                        <path d="M18 9h1.5a2.5 2.5 0 0 0-5H18" />
                        <path d="M4 22h16" />
                        <path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22" />
                        <path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22" />
                        <path d="M18 2H6v7a6 6 0 0 0 12 0V2Z" />
                    </svg></div><span class="dif-card-title">Estrutura para Team Building "Masterchef"</span>
            </div>
            <div class="dif-card">
                <div class="dif-card-icon"><svg viewBox="0 0 24 24">
                        <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
                        <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
                    </svg></div><span class="dif-card-title">Estrutura para aulas de gastronomia</span>
            </div>
        </div>
    </section>

    <section class="depoimento">
        <span class="dep-icon">"</span>
        <blockquote class="dep-quote">O Casa Voss transformou nosso evento anual em algo que vai muito além do
            corporativo. Foi uma experiência de marca.</blockquote>
        <p class="dep-author">Diretora de Marketing · Empresa parceira</p>
    </section>

    <div class="galeria-header" id="galeria">
        <span class="section-tag">Galeria</span>
        <h2 class="section-title">Onde as ideias ganham forma</h2>
    </div>
    <div class="galeria">
        <div class="galeria-item tall"><img
                src="https://casavoss.com.br/wp-content/uploads/2026/04/Copia-de-064VIZ_IMG_21-Salas_resultado.avif"
                alt="" loading="lazy" /></div>
        <div class="galeria-item"><img
                src="https://casavoss.com.br/wp-content/uploads/2026/04/Copia-de-064VIZ_IMG_23-Camarim_resultado.avif"
                alt="" loading="lazy" /></div>
        <div class="galeria-item"><img
                src="https://casavoss.com.br/wp-content/uploads/2026/04/Copia-de-064VIZ_IMG_10-Pocket-Auditorio_resultado.avif"
                alt="" loading="lazy" /></div>
        <div class="galeria-item"><img
                src="https://casavoss.com.br/wp-content/uploads/2026/04/Copia-de-064VIZ_IMG_20-Estar_resultado.avif"
                alt="" loading="lazy" /></div>
        <div class="galeria-item"><img
                src="https://casavoss.com.br/wp-content/uploads/2026/04/ChatGPT-Image-7-de-abr.-de-2026-22_07_06_resultado.avif"
                alt="" loading="lazy" /></div>
    </div>

    <!-- ═══ FORMULÁRIO COM CAMPO EMPRESA ═══ -->
    <section class="contato-section" id="contato">
        <div class="contato-info">
            <span class="section-tag">Próximo passo</span>
            <h2 class="section-title">Vamos dar forma ao seu próximo<br><em>evento corporativo?</em></h2>
            <p class="section-body">Preencha seus dados e receba um orçamento personalizado para sua empresa.</p>
            <a href="#" class="btn-whatsapp"
                onclick="event.preventDefault();document.getElementById('wppFloatBtn').click()"><svg
                    viewBox="0 0 24 24">
                    <path
                        d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                </svg>Fale pelo WhatsApp</a>
        </div>
        <div class="contato-form-wrap">
            <div class="corporativo-form-card">
                <LeadForm
                    formId="corporativo"
                    project="casavoss"
                    submitUrl="https://server3n8n.dmove.com.br/webhook/casa-voss"
                    submitText="SOLICITAR ORÇAMENTO PERSONALIZADO"
                    prefix="corporativo"
                    gridId="corporativoFormGrid"
                    submitId="corporativoSubmitBtn"
                    honeypot={true}
                    successTitle="Solicitação recebida"
                    successText="Recebemos seu pedido de orçamento.<br>Em breve entraremos em contato pelo WhatsApp ou e-mail."
                    fields={[
                        { name: 'form_fields[nome]', id: 'Nome', type: 'text', label: 'Nome', placeholder: 'Nome', autocomplete: 'given-name', maxlength: 100, required: true, full: true, errorText: 'Informe seu nome.', errorId: 'errNome' },
                        { name: 'form_fields[empresa]', id: 'Empresa', type: 'text', label: 'Empresa', placeholder: 'Nome da empresa', autocomplete: 'organization', maxlength: 200, required: true, full: true, errorText: 'Informe sua empresa.', errorId: 'errEmpresa' },
                        {
                            type: 'row',
                            fields: [
                                { name: 'form_fields[telefone]', id: 'Telefone', type: 'tel', label: 'WhatsApp', placeholder: '(11) 9 0000-0000', autocomplete: 'tel', maxlength: 20, required: true, errorText: 'Informe um WhatsApp válido.', errorId: 'errTelefone' },
                                { name: 'form_fields[email]', id: 'Email', type: 'email', label: 'E-mail', placeholder: 'E-mail', autocomplete: 'email', maxlength: 200, required: true, errorText: 'Informe um e-mail válido.', errorId: 'errEmail' },
                            ]
