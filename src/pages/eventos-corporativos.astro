---
// Gerado a partir de: eventos-corporativos.html
import Base from '../layouts/Base.astro';
import config from '../../config.json';
import Img from '../components/ui/Img.astro';
import Video from '../components/ui/Video.astro';
import LeadForm from '../components/forms/LeadForm.astro';
import { getImage } from 'astro:assets';
import salaReuniaoImg from '../assets/images/salas_reuniao.eventos-corporativos02.webp';
import '../styles/eventos-corporativos.css';
const posterSrc = (await getImage({ src: salaReuniaoImg, width: 1280 })).src;
---

<Base
  title="Eventos Corporativos – Espaço Fit Eventos"
  description="Salas versáteis, tecnologia integrada e uma operação preparada para receber desde encontros estratégicos até grandes convenções corporativas."
  ogImage="/images/og-eventos-corporativos.webp"
>
<!-- HEADER -->
<header id="header">
  <div class="container">
    <a href="#" class="logo">
      <Img src="logo.fiteventos.webp" alt="Espaço Fit Eventos" priority />
    </a>
    <nav id="nav">
      <a href="#espacos">Ambientes</a>
      <a href="#estrutura">Estrutura</a>
      <a href="#gastronomia">Gastronomia</a>
      <a href="#galeria">Galeria</a>
    </nav>
    <div class="hamburger" id="hamburger" onclick="toggleNav()">
      <span></span><span></span><span></span>
    </div>
  </div>
</header>

<!-- HERO -->
<section id="hero">
  <div id="hero-slides">
    <div class="hero-slide active"><Img src="hero.eventos-corporativos01.webp" alt="" priority width={1920} /></div>
    <div class="hero-slide"><Img src="hero.eventos-corporativos02.webp" alt="" width={1920} /></div>
    <div class="hero-slide"><Img src="hero.eventos-corporativos03.webp" alt="" width={1920} /></div>
    <div class="hero-slide"><Img src="hero.eventos-corporativos04.webp" alt="" width={1920} /></div>
    <div class="hero-slide"><Img src="hero.eventos-corporativos05.webp" alt="" width={1920} /></div>
    <div class="hero-slide"><Img src="hero.eventos-corporativos06.webp" alt="" width={1920} /></div>
  </div>
  <div class="hero-overlay"></div>
  <div class="container">
    <div class="hero-content">
      <div class="hero-tag">São Paulo · Eventos Corporativos</div>
      <h1>O espaço ideal para eventos corporativos que exigem impacto, <em>flexibilidade e excelência</em></h1>
      <p>Salas versáteis, tecnologia integrada e uma operação preparada para receber desde encontros estratégicos até grandes convenções corporativas.</p>
      <div class="hero-actions">
        <a href="#contato" class="btn btn-primary">Solicite orçamento</a>
      </div>
    </div>
  </div>
</section>

<!-- PROVA SOCIAL -->
<section id="prova-social">
  <div class="stats-bar">
    <div class="stat-item">
      <div class="stat-number">10</div>
      <div class="stat-label">Andares</div>
    </div>
    <div class="stat-item">
      <div class="stat-number">17</div>
      <div class="stat-label">Ambientes</div>
    </div>
    <div class="stat-item">
      <div class="stat-number">+500</div>
      <div class="stat-label">Convidados</div>
    </div>
    <div class="stat-item">
      <div class="stat-number">+10</div>
      <div class="stat-label">Anos de experiência</div>
    </div>
  </div>
</section>

<!-- AUTORIDADE -->
<section id="autoridade">
  <div class="autoridade-media">
    <Video
      src="/sobre.eventos-corporativos.mp4"
      poster={posterSrc}
      title="Espaço Fit Eventos — Eventos Corporativos"
      description="Conheça a estrutura do Espaço Fit Eventos para eventos corporativos."
      uploadDate="2026-05-14"
      duration="PT1M"
    />
  </div>
  <div class="autoridade-content">
    <span class="label">Sobre o espaço</span>
    <h2>Uma estrutura que se adapta<br><em>ao formato do seu evento</em></h2>
    <p>Desde 2012, o Espaço Fit Eventos atende empresas de médio e grande porte que buscam estrutura, organização e excelência na execução de seus eventos.</p>
    <p>Com uma operação ativa e ambientes preparados para alta demanda, o espaço se consolidou como uma escolha confiável para treinamentos, convenções e eventos empresariais de grande porte.</p>
  </div>
</section>

<!-- ESPAÇOS -->
<section id="espacos">
  <div class="section-header container">
    <span class="label">Nossos ambientes</span>
    <h2>Flexibilidade para criar o<br><em style="color:var(--rose)">evento do seu jeito</em></h2>
    <p>Espaços versáteis, funcionais e prontos para diferentes dinâmicas corporativas, de reuniões estratégicas a grandes apresentações.</p>
  </div>
  <div class="espacos-grid">
    <div class="espaco-card wide">
      <div class="card-slides">
        <div class="card-slide active"><Img src="salas_treinamento.eventos-corporativos01.webp" alt="Salas de Treinamento e Auditórios" /></div>
        <div class="card-slide"><Img src="salas_treinamento.eventos-corporativos02.webp" alt="Salas de Treinamento e Auditórios" /></div>
        <div class="card-slide"><Img src="salas_treinamento.eventos-corporativos03.webp" alt="Salas de Treinamento e Auditórios" /></div>
        <div class="card-slide"><Img src="salas_treinamento.eventos-corporativos04.webp" alt="Salas de Treinamento e Auditórios" /></div>
        <div class="card-slide"><Img src="salas_treinamento.eventos-corporativos05.webp" alt="Salas de Treinamento e Auditórios" /></div>
      </div>
      <div class="espaco-overlay">
        <div class="espaco-info">
          <h3>Salas de Treinamento e Auditórios</h3>
          <p>Layouts flexíveis, auditório, U, escolar, mesas redondas, com capacidade para 10 a 530 convidados</p>
        </div>
      </div>
    </div>
    <div class="espaco-card">
      <div class="card-slides">
        <div class="card-slide active"><Img src="Sala_Design.eventos-corporativos01.webp" alt="Salas Design Thinking" /></div>
        <div class="card-slide"><Img src="Sala_Design.eventos-corporativos02.webp" alt="Salas Design Thinking" /></div>
        <div class="card-slide"><Img src="Sala_Design.eventos-corporativos03.webp" alt="Salas Design Thinking" /></div>
        <div class="card-slide"><Img src="Sala_Design.eventos-corporativos04.webp" alt="Salas Design Thinking" /></div>
        <div class="card-slide"><Img src="Sala_Design.eventos-corporativos05.webp" alt="Salas Design Thinking" /></div>
        <div class="card-slide"><Img src="Sala_Design.eventos-corporativos06.webp" alt="Salas Design Thinking" /></div>
      </div>
      <div class="espaco-overlay">
        <div class="espaco-info">
          <h3>Salas Design Thinking</h3>
          <p>Espaços que estimulam troca, criatividade e construção coletiva</p>
        </div>
      </div>
    </div>
    <div class="espaco-card">
      <div class="card-slides">
        <div class="card-slide active"><Img src="salas_vip.eventos-corporativos01.webp" alt="Sala VIP" /></div>
        <div class="card-slide"><Img src="salas_vip.eventos-corporativos02.webp" alt="Sala VIP" /></div>
        <div class="card-slide"><Img src="salas_vip.eventos-corporativos03.webp" alt="Sala VIP" /></div>
      </div>
      <div class="espaco-overlay">
        <div class="espaco-info">
          <h3>Sala VIP</h3>
          <p>Ambiente exclusivo para receber convidados com conforto e privacidade</p>
        </div>
      </div>
    </div>
    <div class="espaco-card">
      <div class="card-slides">
        <div class="card-slide active"><Img src="salas_reuniao.eventos-corporativos01.webp" alt="Sala de Reunião" /></div>
        <div class="card-slide"><Img src="salas_reuniao.eventos-corporativos02.webp" alt="Sala de Reunião" /></div>
      </div>
      <div class="espaco-overlay">
        <div class="espaco-info">
          <h3>Sala de Reunião</h3>
          <p>Ideal para reuniões executivas, alinhamentos e apresentações estratégicas</p>
        </div>
      </div>
    </div>
    <div class="espaco-card">
      <div class="card-slides">
        <div class="card-slide active"><Img src="camarim.eventos-corporativos01.webp" alt="Camarim" /></div>
        <div class="card-slide"><Img src="camarim.eventos-corporativos02.webp" alt="Camarim" /></div>
        <div class="card-slide"><Img src="camarim.eventos-corporativos03.webp" alt="Camarim" /></div>
      </div>
      <div class="espaco-overlay">
        <div class="espaco-info">
          <h3>Camarim</h3>
          <p>Estrutura de apoio para palestrantes, produções e convidados especiais</p>
        </div>
      </div>
    </div>
  </div>
  <div class="espaco-cta container">
    <a href="#contato" class="btn btn-gold">Descubra o espaço ideal para o seu evento</a>
  </div>
</section>

<!-- ESTRUTURA + TECNOLOGIA -->
<section id="estrutura">
  <div class="estrutura-lead container">
    <span class="label" style="color:var(--rose)">Infraestrutura</span>
    <h2>Soluções integradas para eventos <em>presenciais, híbridos e digitais</em></h2>
    <p>Do audiovisual à circulação entre ambientes, cada detalhe é planejado para garantir fluidez, conforto e eficiência durante todo o evento.</p>
  </div>
  <div class="estrutura-grid">
    <div class="estrutura-item">
      <Img src="Painéis.eventos-corporativos.webp" alt="Painéis de LED e projeção mapeada" />
      <div class="estrutura-caption">Painéis de LED e projeção mapeada</div>
    </div>
    <div class="estrutura-item">
      <Img src="Transmissão.eventos-corporativos.webp" alt="Transmissão ao vivo e streaming" />
      <div class="estrutura-caption">Transmissão ao vivo e streaming</div>
    </div>
    <div class="estrutura-item">
      <Img src="Audiovisual.eventos-corporativos.webp" alt="Estrutura audiovisual completa" />
      <div class="estrutura-caption">Estrutura audiovisual completa</div>
    </div>
  </div>
</section>

<!-- TIPOS DE EVENTOS -->
<section id="eventos">
  <div class="section-header container">
    <span class="label">Versatilidade</span>
    <h2>Versatilidade para eventos de<br><em style="color:var(--white)">todos os formatos</em></h2>
  </div>
  <div class="eventos-grid">
      <div class="evento-item">
        <div class="evento-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
            <path d="M7 8l3 3 5-5"/>
          </svg>
        </div>
        <h3>Treinamentos e capacitações</h3>
      </div>
      <div class="evento-item">
        <div class="evento-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </div>
        <h3>Convenções e encontros empresariais</h3>
      </div>
      <div class="evento-item">
        <div class="evento-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 18h6M10 22h4"/>
            <path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/>
          </svg>
        </div>
        <h3>Workshops e imersões</h3>
      </div>
      <div class="evento-item">
        <div class="evento-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/>
            <path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><circle cx="12" cy="20" r="1" fill="currentColor"/>
          </svg>
        </div>
        <h3>Eventos híbridos e transmissões ao vivo</h3>
      </div>
      <div class="evento-item">
        <div class="evento-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/>
            <path d="M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/>
            <path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/>
            <path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>
          </svg>
        </div>
        <h3>Lançamentos e ativações de marca</h3>
      </div>
      <div class="evento-item">
        <div class="evento-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="m11 17 2 2a1 1 0 1 0 3-3"/>
            <path d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-.88.88a1 1 0 1 1-3-3l2.81-2.81a5.79 5.79 0 0 1 7.06-.87l.47.28a2 2 0 0 0 1.42.25L21 4"/>
            <path d="m21 3 1 11h-1"/>
            <path d="M3 3 2 14l6.5 6.5"/>
            <path d="M3 4h8"/>
          </svg>
        </div>
        <h3>Confraternizações corporativas</h3>
      </div>
    </div>
  <div class="eventos-cta container">
    <a href="#contato" class="btn btn-gold">Reserve sua data</a>
  </div>
</section>

<!-- DIFERENCIAIS -->
<section id="diferenciais">
  <div class="diferenciais-head container">
      <span class="label" style="color:var(--rose)">Por que escolher o Fit</span>
      <h2>Os diferenciais que elevam<br><em>a experiência do seu evento</em></h2>
  </div>
  <div class="diferenciais-grid">
      <div class="diferencial-item">
        <div class="diferencial-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
          </svg>
        </div>
        <h3>Localização estratégica</h3>
      </div>
      <div class="diferencial-item">
        <div class="diferencial-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
          </svg>
        </div>
        <h3>Estrutura completa e tecnológica</h3>
      </div>
      <div class="diferencial-item">
        <div class="diferencial-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
          </svg>
        </div>
        <h3>Flexibilidade de layouts</h3>
      </div>
      <div class="diferencial-item">
        <div class="diferencial-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </div>
        <h3>Atendimento altamente elogiado</h3>
      </div>
      <div class="diferencial-item">
        <div class="diferencial-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>
          </svg>
        </div>
        <h3>Gastronomia própria e personalizada</h3>
      </div>
      <div class="diferencial-item">
        <div class="diferencial-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
        </div>
        <h3>Sala VIP e camarim exclusivo</h3>
      </div>
      <div class="diferencial-item">
        <div class="diferencial-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
          </svg>
        </div>
        <h3>Excelente custo-benefício</h3>
      </div>
  </div>
</section>

<!-- GASTRONOMIA -->
<section id="gastronomia">
  <div class="gastro-grid container">
      <div class="gastro-text">
        <span class="label">Gastronomia</span>
        <h2>Gastronomia pensada<br><em style="color:var(--rose)">para impressionar</em></h2>
        <p>Do coffee break ao jantar corporativo, o Espaço Fit oferece uma experiência gastronômica versátil e personalizada, assinada pelo premiado <b>Chef Dalton Rangel</b>.</p>
        <p>Menus adaptados ao perfil do evento e dos convidados, incluindo <b>alternativas veganas e vegetarianas</b>.</p>
        <div class="gastro-tags">
          <span class="gastro-tag">Coffee break</span>
          <span class="gastro-tag">Almoço corporativo</span>
          <span class="gastro-tag">Finger foods</span>
          <span class="gastro-tag">Jantar completo</span>
          <span class="gastro-tag">Menu vegano</span>
          <span class="gastro-tag">Menu vegetariano</span>
        </div>
      </div>
      <div class="gastro-image">
        <div class="gastro-slides">
          <div class="gastro-slide active"><Img src="galeria.eventos-corporativos01.webp" alt="Gastronomia 1" priority /></div>
          <div class="gastro-slide"><Img src="galeria.eventos-corporativos02.webp" alt="Gastronomia 2" /></div>
          <div class="gastro-slide"><Img src="galeria.eventos-corporativos03.webp" alt="Gastronomia 3" /></div>
          <div class="gastro-slide"><Img src="galeria.eventos-corporativos04.webp" alt="Gastronomia 4" /></div>
          <div class="gastro-slide"><Img src="galeria.eventos-corporativos05.webp" alt="Gastronomia 5" /></div>
          <div class="gastro-slide"><Img src="galeria.eventos-corporativos06.webp" alt="Gastronomia 6" /></div>
          <div class="gastro-slide"><Img src="galeria.eventos-corporativos07.webp" alt="Gastronomia 7" /></div>
          <div class="gastro-slide"><Img src="galeria.eventos-corporativos08.webp" alt="Gastronomia 8" /></div>
          <div class="gastro-slide"><Img src="galeria.eventos-corporativos09.webp" alt="Gastronomia 9" /></div>
          <div class="gastro-slide"><Img src="galeria.eventos-corporativos10.webp" alt="Gastronomia 10" /></div>
          <div class="gastro-slide"><Img src="galeria.eventos-corporativos11.webp" alt="Gastronomia 11" /></div>
          <div class="gastro-slide"><Img src="galeria.eventos-corporativos12.webp" alt="Gastronomia 12" /></div>
          <div class="gastro-slide"><Img src="galeria.eventos-corporativos13.webp" alt="Gastronomia 13" /></div>
          <div class="gastro-slide"><Img src="galeria.eventos-corporativos14.webp" alt="Gastronomia 14" /></div>
          <div class="gastro-slide"><Img src="galeria.eventos-corporativos15.webp" alt="Gastronomia 15" /></div>
          <div class="gastro-slide"><Img src="galeria.eventos-corporativos16.webp" alt="Gastronomia 16" /></div>
        </div>
        <div class="gastro-badge">
          Assinado por<strong>Chef Dalton Rangel</strong>
        </div>
      </div>
  </div>
</section>

<!-- CLIENTES -->
<section id="clientes">
  <div class="clientes-header container">
    <span class="label">Parceiros</span>
    <h2>Seu evento no mesmo<br><em>espaço de grandes empresas</em></h2>
  </div>

  {/* Fileira 1 — logos 01 a 66 */}
  <div class="marquee-wrap">
    <div class="marquee-track marquee-esquerda">
      <div class="logo-item"><img src="/logos/logo-cliente01.png" alt="Cliente 1" /></div>
      <div class="logo-item"><img src="/logos/logo-cliente02.png" alt="Cliente 2" /></div>
      <div class="logo-item"><img src="/logos/logo-cliente03.png" alt="Cliente 3" /></div>
      <div class="logo-item"><img src="/logos/logo-cliente04.png" alt="Cliente 4" /></div>
      <div class="logo-item"><img src="/logos/logo-cliente05.png" alt="Cliente 5" /></div>
      <div class="logo-item"><img src="/logos/logo-cliente06.png" alt="Cliente 6" /></div>
      <div class="logo-item"><img src="/logos/logo-cliente07.png" alt="Cliente 7" /></div>
      <div class="logo-item"><img src="/logos/logo-cliente08.png" alt="Cliente 8" /></div>
      <div class="logo-item"><img src="/logos/logo-cliente09.png" alt="Cliente 9" /></div>
      <div class="logo-item"><img src="/logos/logo-cliente10.png" alt="Cliente 10" /></div>
      <div class="logo-item"><img src="/logos/logo-cliente11.png" alt="Cliente 11" /></div>
      <div class="logo-item"><img src="/logos/logo-cliente12.png" alt="Cliente 12" /></div>
