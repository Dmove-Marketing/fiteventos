<!-- CONTATO -->
<section id="contato">
  <div class="contato-left">
    <span class="label" style="color:var(--rose)">Próximo passo</span>
    <h2>Vamos planejar seu próximo<br><em>evento corporativo?</em></h2>
    <p>Preencha seus dados e receba um orçamento personalizado para sua empresa.</p>
    <div class="contato-address">
      <div class="contato-address-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
        </svg>
        <span>Av. Alfredo Egídio de Souza Aranha, 384<br>Chácara Santo Antônio, São Paulo – SP</span>
      </div>
      <div class="contato-address-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.1a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.18h3a2 2 0 0 1 2 1.72c.127.96.36 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.34 1.85.573 2.81.7a2 2 0 0 1 1.72 2.02z"/>
        </svg>
        <span>Fácil acesso pela Marginal Pinheiros · Próximo ao Aeroporto de Congonhas</span>
      </div>
    </div>
  </div>
  <div class="contato-form-wrap">
    <LeadForm
      formId="lead-form"
      project={config.project_slug}
      submitUrl={config.forms['lead-form'].webhooks[0]}
      redirectUrl={config.forms['lead-form'].redirect_on_success}
      submitText="Solicitar orçamento"
      honeypot
      fields={[
        { name: 'nome', type: 'text', placeholder: 'Seu nome completo', required: true, full: true },
        { name: 'email', type: 'email', placeholder: 'seu@email.com', required: true, full: true },
        { name: 'telefone', type: 'tel', placeholder: '(11) 9 0000-0000', required: true },
        { name: 'data', type: 'text', placeholder: 'Data do evento', required: true },
        { name: 'convidados', type: 'number', placeholder: 'Nº de pessoas', required: true },
        { name: 'tipo_evento', type: 'select', placeholder: '', required: true, options: [
          { value: '', label: 'Tipo de evento...' },
          { value: 'Treinamento / Capacitação', label: 'Treinamento / Capacitação' },
          { value: 'Convenção / Encontro empresarial', label: 'Convenção / Encontro empresarial' },
          { value: 'Workshop / Imersão', label: 'Workshop / Imersão' },
          { value: 'Evento híbrido / Transmissão ao vivo', label: 'Evento híbrido / Transmissão ao vivo' },
          { value: 'Lançamento / Ativação de marca', label: 'Lançamento / Ativação de marca' },
          { value: 'Confraternização corporativa', label: 'Confraternização corporativa' },
          { value: 'Outros', label: 'Outros' }
        ] },
        { name: 'mensagem', type: 'textarea', placeholder: 'Detalhes adicionais (não obrigatório)', required: false, full: true },
      ]}
    />
  </div>
</section>

