---
// src/components/forms/LeadForm.astro

interface FieldOption {
  value: string;
  label: string;
  disabled?: boolean;
  selected?: boolean;
}

interface Field {
  name: string;
  type: 'text' | 'email' | 'tel' | 'number' | 'select' | 'textarea' | 'hidden';
  label?: string;
  placeholder?: string;
  required?: boolean;
  full?: boolean;
  id?: string;
  autocomplete?: string;
  errorText?: string;
  errorId?: string;
  maxlength?: number;
  min?: string;
  max?: string;
  readonly?: boolean;
  rows?: number;
  options?: FieldOption[];
  value?: string;
}

interface FieldRow {
  type: 'row';
  fields: Field[];
}

type AnyField = Field | FieldRow;

interface Props {
  formId: string;
  project: string;
  apiUrl?: string;
  submitUrl?: string;
  redirectUrl?: string;
  submitText?: string;
  fields?: AnyField[];
  class?: string;
  prefix?: string;
  gridId?: string;
  submitId?: string;
  honeypot?: boolean;
  successTitle?: string;
  successText?: string;
}

const {
  formId,
  project,
  apiUrl = '',
  submitUrl,
  redirectUrl,
  submitText = 'Enviar',
  fields = [
    { name: 'nome', type: 'text', placeholder: 'Seu nome completo', required: true },
    { name: 'email', type: 'email', placeholder: 'Seu melhor e-mail', required: true },
    { name: 'telefone', type: 'tel', placeholder: 'WhatsApp com DDD', required: true },
  ] as AnyField[],
  class: className,
  prefix = '',
  gridId,
  submitId,
  honeypot = false,
  successTitle = 'Solicitação recebida',
  successText = 'Recebemos seu pedido.<br>Em breve entraremos em contato pelo WhatsApp ou e-mail.',
} = Astro.props;

const formElemId = `form-${formId}`;
const theGridId = gridId || (prefix ? `${prefix}FormGrid` : `${formId}Grid`);
const theSubmitId = submitId || (prefix ? `${prefix}SubmitBtn` : `${formId}SubmitBtn`);
const theSuccessId = prefix ? `${prefix}Success` : `${formId}Success`;
const theMsgId = prefix ? `${prefix}FormMsg` : `${formId}FormMsg`;

// CSS helpers: use prefix classes when prefix set, otherwise generic lead-form classes
const p = prefix ? prefix : null;
const cxGrid    = p ? `${p}-form-grid`    : 'lead-form-grid';
const cxRow     = p ? `${p}-form-row`     : 'form-row';
const cxLabel   = p ? `${p}-label`        : 'form-label';
const cxInput   = p ? `${p}-input`        : 'form-input';
const cxSelect  = p ? `${p}-select`       : 'form-select';
const cxArea    = p ? `${p}-textarea`     : 'form-textarea';
const cxError   = p ? `${p}-field-error`  : 'field-error';
const cxMsg     = p ? `${p}-form-msg`     : 'form-error';
const cxFooter  = p ? `${p}-form-footer`  : 'form-footer';
const cxSuccess = p ? `${p}-success-state`  : 'form-success-state';
const cxSIcon   = p ? `${p}-success-icon`   : 'form-success-icon';
const cxSTitle  = p ? `${p}-success-title`  : 'form-success-title';
const cxSText   = p ? `${p}-success-text`   : 'form-success-text';
const cxSubmit  = p ? `${p}-submit form-submit` : 'btn btn-primary form-submit';
const groupCls  = (full?: boolean) => {
  const base = p ? `${p}-form-group` : 'form-group';
  return full ? `${base} full` : base;
};
---

<form
  id={formElemId}
  name={formId}
  class:list={[!prefix && 'lead-form', className]}
  data-form-id={formId}
  data-project={project}
  data-api-url={apiUrl}
  data-submit-url={submitUrl}
  data-redirect={redirectUrl}
  data-grid-id={theGridId}
  data-success-id={theSuccessId}
  novalidate
>
  {honeypot && (
    <div class="hp-field" aria-hidden="true">
      <label for={`${formId}_website`}>Deixe este campo em branco</label>
      <input type="text" id={`${formId}_website`} name="website" tabindex="-1" autocomplete="off" />
    </div>
  )}

  <div class={cxGrid} id={theGridId}>
    {fields.map((fieldOrRow) => {
      if (fieldOrRow.type === 'row') {
        const row = fieldOrRow as FieldRow;
        return (
          <div class={cxRow}>
            {row.fields.map((f) => (
              <div class={groupCls(f.full)}>
                {f.label && <label class={cxLabel} for={f.id ?? f.name}>{f.label}</label>}
                {f.type === 'select' ? (
                  <select class={cxSelect} name={f.name} id={f.id ?? f.name} required={f.required}>
                    {f.options?.map((opt) => (
                      <option value={opt.value} disabled={opt.disabled} selected={opt.selected}>{opt.label}</option>
                    ))}
                  </select>
                ) : f.type === 'textarea' ? (
                  <textarea class={cxArea} name={f.name} id={f.id ?? f.name} rows={f.rows ?? 4} placeholder={f.placeholder} required={f.required}></textarea>
                ) : f.type === 'hidden' ? (
                  <input type="hidden" name={f.name} id={f.id ?? f.name} value={f.value} />
                ) : (
                  <input
                    class={cxInput}
                    type={f.type}
                    name={f.name}
                    id={f.id ?? f.name}
                    placeholder={f.placeholder}
                    required={f.required}
                    autocomplete={f.autocomplete}
                    maxlength={f.maxlength}
                    min={f.min}
                    max={f.max}
                    readonly={f.readonly}
                  />
                )}
                {f.errorText && <span class={cxError} id={f.errorId}>{f.errorText}</span>}
              </div>
            ))}
          </div>
        );
      }

      const f = fieldOrRow as Field;

      if (f.type === 'hidden') {
        return <input type="hidden" name={f.name} id={f.id ?? f.name} value={f.value} />;
      }

      return (
        <div class={groupCls(f.full)}>
          {f.label && <label class={cxLabel} for={f.id ?? f.name}>{f.label}</label>}
          {f.type === 'select' ? (
            <select class={cxSelect} name={f.name} id={f.id ?? f.name} required={f.required}>
              {f.options?.map((opt) => (
                <option value={opt.value} disabled={opt.disabled} selected={opt.selected}>{opt.label}</option>
              ))}
            </select>
          ) : f.type === 'textarea' ? (
            <textarea class={cxArea} name={f.name} id={f.id ?? f.name} rows={f.rows ?? 4} placeholder={f.placeholder} required={f.required}></textarea>
          ) : (
            <input
              class={cxInput}
              type={f.type}
              name={f.name}
              id={f.id ?? f.name}
              placeholder={f.placeholder}
              required={f.required}
              autocomplete={f.autocomplete}
              maxlength={f.maxlength}
              min={f.min}
              max={f.max}
              readonly={f.readonly}
            />
          )}
          {f.errorText && <span class={cxError} id={f.errorId}>{f.errorText}</span>}
        </div>
      );
    })}

    <div class={groupCls(true)}>
      <button type="submit" class={cxSubmit} id={theSubmitId}>
        <span class="btn-text">{submitText}</span>
        <span class="btn-loading" style="display:none;">
          <svg class="spinner" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" />
          </svg>
          Enviando...
        </span>
      </button>
    </div>

    <div class={cxMsg} id={theMsgId}></div>
    <p class={cxFooter}>Ao enviar, você concorda com nossa política de privacidade.</p>
  </div>

  <div class={cxSuccess} id={theSuccessId}>
    <div class={cxSIcon}>
      <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg>
    </div>
    <h3 class={cxSTitle}>{successTitle}</h3>
    <p class={cxSText} set:html={successText}></p>
  </div>
</form>

<script>
  function initForms() {
    const forms = document.querySelectorAll<HTMLFormElement>('form[data-form-id]');
    forms.forEach((form) => {
      let started = false;
      const formId  = form.dataset.formId!;
      const project = form.dataset.project!;
      const apiUrl  = form.dataset.apiUrl ?? '';
      const submitUrl = form.dataset.submitUrl || `${apiUrl}/submit`;
      const redirectUrl = form.dataset.redirect;
      const gridId    = form.dataset.gridId;
      const successId = form.dataset.successId;

      form.addEventListener('focusin', () => {
        if (!started) {
          started = true;
          (window as any).dataLayer?.push({ event: 'form_start', form_id: formId, project });
        }
      });

      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        // Honeypot check
        const hp = form.querySelector<HTMLInputElement>('[name="website"]');
        if (hp && hp.value) return;

        const submitBtn  = form.querySelector<HTMLButtonElement>('.form-submit');
        const btnText    = form.querySelector<HTMLElement>('.btn-text');
        const btnLoading = form.querySelector<HTMLElement>('.btn-loading');
        const msgEl      = gridId ? document.getElementById(gridId)?.querySelector('[id$="FormMsg"]') as HTMLElement | null : null;

        if (submitBtn) submitBtn.disabled = true;
        if (btnText)    btnText.style.display = 'none';
        if (btnLoading) btnLoading.style.display = 'inline-flex';
        if (msgEl)      msgEl.style.display = 'none';

        const formData = new FormData(form);
        const data: Record<string, string> = {};
        formData.forEach((v, k) => { if (k !== 'website') data[k] = v.toString(); });

        const trackingRaw = sessionStorage.getItem('dmove_tracking');
        const tracking    = trackingRaw ? JSON.parse(trackingRaw) : {};
        const firstVisit  = sessionStorage.getItem('dmove_first_visit') || '';

        const payload = {
          project,
          form_id: formId,
          data,
          tracking: { ...tracking, first_visit: firstVisit, submitted_at: new Date().toISOString(), page_url: window.location.href },
        };

        try {
          const res = await fetch(submitUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });

          if (!res.ok) throw new Error('http_' + res.status);

          let json: any = {};
          try { json = await res.json(); } catch {}

          (window as any).dataLayer?.push({ event: 'form_submit', form_id: formId, project, ...data });

          const redir = redirectUrl || json.redirect;
          if (redir) {
            window.location.href = redir;
            return;
          }

          // Show success state: hide grid, reveal success div
          const gridEl    = gridId    ? document.getElementById(gridId)    : null;
          const successEl = successId ? document.getElementById(successId) : null;

          if (gridEl && successEl) {
            gridEl.style.display = 'none';
            successEl.classList.add('active');
          } else {
            form.innerHTML = `
              <div class="form-success">
                <div class="form-success-icon">✓</div>
                <p class="form-success-title">Enviado com sucesso!</p>
                <p class="form-success-text">Em breve entraremos em contato.</p>
              </div>`;
          }
        } catch (err: any) {
          (window as any).dataLayer?.push({ event: 'form_error', form_id: formId, error: err.message });

          if (msgEl) {
            msgEl.innerHTML = 'Erro ao enviar. Tente novamente ou entre em contato pelo <a href="mailto:contato@casavoss.com.br">contato@casavoss.com.br</a>.';
            msgEl.style.display = 'block';
          }
          if (submitBtn)  submitBtn.disabled = false;
          if (btnText)    btnText.style.display = 'inline';
          if (btnLoading) btnLoading.style.display = 'none';
        }
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initForms);
  } else {
    initForms();
  }
</script>

<style>
  /* Styles only applied when no prefix is used (generic lead-form mode) */
  .lead-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-md, 1rem);
    width: 100%;
    max-width: 440px;
  }

  .lead-form-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-md, 1rem);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md, 1rem);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .form-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-primary, #111);
  }

  .form-input,
  .form-select,
  .form-textarea {
    width: 100%;
    padding: 10px 14px;
    border: 1px solid var(--border, #d1d5db);
    border-radius: 6px;
    font-size: 0.95rem;
    background: #fff;
    color: var(--text-primary, #111);
    transition: border-color 0.15s;
  }

  .form-input:focus,
  .form-select:focus,
  .form-textarea:focus {
    outline: none;
    border-color: var(--color-primary, #2563eb);
  }

  .field-error {
    font-size: 0.78rem;
    color: #ef4444;
    display: none;
  }

  .field-error.visible {
    display: block;
  }

  .form-submit {
    width: 100%;
    margin-top: var(--space-sm, 0.5rem);
    font-size: 1.05rem;
    padding: 14px var(--space-xl, 2rem);
    cursor: pointer;
  }

  .form-submit:disabled {
    opacity: 0.7;
    cursor: not-allowed;
    transform: none !important;
  }

  .btn-loading {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .spinner {
    animation: spin 1s linear infinite;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  .form-error {
    color: #ef4444;
    font-size: 0.875rem;
    margin-top: 4px;
    display: none;
  }

  .form-success-state {
    text-align: center;
    padding: var(--space-xl, 2rem);
  }

  .form-success-icon {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-md, 1rem);
    background: var(--gradient-primary, #2563eb);
    border-radius: 50%;
    font-size: 1.5rem;
    color: white;
  }

  .form-success-title {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text-primary, #111);
    margin-bottom: 4px;
  }

  .form-success-text {
    color: var(--text-secondary, #666);
    font-size: 0.9rem;
  }

  .form-footer {
    font-size: 0.75rem;
    color: var(--text-secondary, #888);
    text-align: center;
  }

  /* Success state hidden by default */
  .form-success-state {
    display: none;
  }
  .form-success-state.active {
    display: block;
  }
</style>
